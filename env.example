# FORGE — Environment Variables
# Copy this file to .env and fill in your values
# Never commit your actual .env file to git

# Flask secret key — used for session signing
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Admin panel password
ADMIN_PASSWORD=

# Optional: set to 'development' for debug mode, 'production' for live use
# In production mode, FORGE refuses to boot with default SECRET_KEY/ADMIN_PASSWORD
FLASK_ENV=development

# Vercel deployment hook URL (triggered by tools/publish.py --deploy)
# Get this from Vercel project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=
