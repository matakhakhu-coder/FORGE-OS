# FORGE — Environment Variables
# Copy this file to .env and fill in your values
# Never commit your actual .env file to git

# ── Required ─────────────────────────────────────────────────────────────────

# Flask secret key — used for session signing and CSRF protection
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FORGE_SECRET_KEY=

# Admin panel password — required for entity CRUD and admin operations
FORGE_ADMIN_PASSWORD=

# ── Server Mode ──────────────────────────────────────────────────────────────

# Set to 'production' for live use — FORGE refuses to boot without
# FORGE_SECRET_KEY and FORGE_ADMIN_PASSWORD in production mode
FLASK_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────

# Override database path (default: project-root/database.db)
# FORGE_DB=

# ── Collectors (optional) ────────────────────────────────────────────────────

# ACLED conflict data — requires myACLED Research tier account
# ACLED_EMAIL=
# ACLED_PASSWORD=

# FLUX SOCINT — X/Twitter monitoring
# X_PULSE_MODE=nitter
# X_BEARER_TOKEN=
# X_PULSE_TARGETS=@handle1,#hashtag1,$CASHTAG1

# NDBC marine buoy stations (comma-separated IDs)
# NDBC_STATIONS=41049,13008

# ── Deployment ───────────────────────────────────────────────────────────────

# Vercel deploy hook — triggered by tools/publish.py --deploy
# Get from: Vercel project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK_URL=
