/* ============================================================================
   FORGE — main.css
   Intelligence Archive Design System  v3.0
   Dark-first · Classified document aesthetic · Editorial precision
   Fonts: Syne (display) + IBM Plex Mono (data) + IBM Plex Sans (body)
   ============================================================================ */

@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;1,300;1,400&display=swap');

/* ── Design Tokens ──────────────────────────────────────────────────────────── */

:root {
  /* ── Surface layers (darkest to brightest) */
  --bg-void:        #05080b;
  --bg-base:        #080d12;
  --bg-surface:     #0c1219;
  --bg-elevated:    #111820;
  --bg-overlay:     #172030;
  --bg-hover:       #1d2a3a;

  /* ── Borders */
  --border-subtle:  rgba(255,255,255,0.04);
  --border-dim:     rgba(255,255,255,0.07);
  --border-mid:     rgba(255,255,255,0.12);
  --border-bright:  rgba(255,255,255,0.22);

  /* ── Text */
  --text-primary:   #cfdce8;
  --text-secondary: #7a95aa;
  --text-dim:       #3d5060;
  --text-ghost:     #253040;

  /* ── Accent — amber/forge motif */
  --accent:         #c8943a;
  --accent-bright:  #e0aa4a;
  --accent-muted:   #8a6420;
  --accent-glow:    rgba(200,148,58,0.10);
  --accent-glow-lg: rgba(200,148,58,0.06);

  /* ── Source classification palette */
  --src-verified:    #1e6640;
  --src-verified-bg: rgba(30,102,64,0.15);
  --src-unverified:  #9a6a18;
  --src-unverified-bg: rgba(154,106,24,0.15);
  --src-government:  #1a3e7a;
  --src-government-bg: rgba(26,62,122,0.20);
  --src-leaked:      #7a1a1a;
  --src-leaked-bg:   rgba(122,26,26,0.18);
  --src-citizen:     #2a4050;
  --src-citizen-bg:  rgba(42,64,80,0.20);
  --src-media:       #153a5e;
  --src-media-bg:    rgba(21,58,94,0.20);

  /* ── Category palette */
  --cat-election:    #3a2a7a;
  --cat-security:    #6a1818;
  --cat-unrest:      #6a3a14;
  --cat-legislative: #143a6a;
  --cat-economic:    #164a2a;
  --cat-other:       #202a20;

  /* ── Typography */
  --font-display: 'Syne', sans-serif;
  --font-body:    'IBM Plex Sans', sans-serif;
  --font-mono:    'IBM Plex Mono', monospace;

  /* ── Spacing scale */
  --sp-1:  0.25rem;
  --sp-2:  0.5rem;
  --sp-3:  0.75rem;
  --sp-4:  1rem;
  --sp-5:  1.25rem;
  --sp-6:  1.5rem;
  --sp-8:  2rem;
  --sp-10: 2.5rem;
  --sp-12: 3rem;
  --sp-16: 4rem;

  /* ── Borders radii */
  --r-sm: 2px;
  --r-md: 4px;
  --r-lg: 6px;

  /* ── Transitions */
  --t-fast: 120ms ease;
  --t-mid:  200ms ease;

  /* ── Layout */
  --sidebar-w: 220px;
  --topbar-h:  52px;
}

/* ── Reset ──────────────────────────────────────────────────────────────────── */

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

body {
  font-family: var(--font-body);
  background: var(--bg-base);
  color: var(--text-primary);
  line-height: 1.6;
  min-height: 100vh;
}

a {
  color: var(--accent);
  text-decoration: none;
  transition: color var(--t-fast);
}

a:hover { color: var(--accent-bright); }

/* ── Utility ────────────────────────────────────────────────────────────────── */

.mono { font-family: var(--font-mono); }

mark {
  background: rgba(200,148,58,0.25);
  color: var(--accent-bright);
  padding: 0 2px;
  border-radius: 2px;
}

/* ── Shell: three-panel layout ──────────────────────────────────────────────── */

.shell {
  display: grid;
  grid-template-columns: var(--sidebar-w) 1fr;
  grid-template-rows: var(--topbar-h) 1fr;
  grid-template-areas:
    "topbar topbar"
    "sidebar main";
  min-height: 100vh;
}

/* ── Topbar ─────────────────────────────────────────────────────────────────── */

.topbar {
  grid-area: topbar;
  display: flex;
  align-items: center;
  gap: var(--sp-4);
  padding: 0 var(--sp-6);
  background: var(--bg-void);
  border-bottom: 1px solid var(--border-dim);
  position: sticky;
  top: 0;
  z-index: 100;
}

/* Classified-document scanline texture on topbar */
.topbar::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(255,255,255,0.012) 2px,
    rgba(255,255,255,0.012) 4px
  );
  pointer-events: none;
}

.topbar__wordmark {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.15rem;
  letter-spacing: 0.12em;
  color: var(--accent);
  text-transform: uppercase;
  white-space: nowrap;
  flex-shrink: 0;
  line-height: 1;
}

.topbar__wordmark:hover { color: var(--accent-bright); }

.topbar__wordmark span {
  font-family: var(--font-mono);
  font-weight: 400;
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  display: block;
  margin-top: 2px;
  text-transform: uppercase;
}

/* Topbar search */
.topbar__search {
  flex: 1;
  max-width: 440px;
  display: flex;
  gap: 0;
}

.topbar__search input {
  flex: 1;
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-right: none;
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 0.78rem;
  padding: var(--sp-2) var(--sp-3);
  border-radius: var(--r-sm) 0 0 var(--r-sm);
  outline: none;
  transition: border-color var(--t-fast), background var(--t-fast);
}

.topbar__search input:focus {
  border-color: var(--accent-muted);
  background: var(--bg-overlay);
}

.topbar__search input::placeholder { color: var(--text-dim); }

.topbar__search button {
  background: var(--bg-overlay);
  border: 1px solid var(--border-dim);
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.05em;
  padding: var(--sp-2) var(--sp-3);
  cursor: pointer;
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
  transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
  white-space: nowrap;
}

.topbar__search button:hover {
  background: var(--accent-glow);
  border-color: var(--accent-muted);
  color: var(--accent);
}

/* UTC clock */
.topbar__meta {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  flex-shrink: 0;
}

/* ── Sidebar ─────────────────────────────────────────────────────────────────── */

.sidebar {
  grid-area: sidebar;
  background: var(--bg-void);
  border-right: 1px solid var(--border-dim);
  padding: var(--sp-6) 0;
  position: sticky;
  top: var(--topbar-h);
  height: calc(100vh - var(--topbar-h));
  overflow-y: auto;
  overflow-x: hidden;
}

/* Subtle gradient at bottom of sidebar */
.sidebar::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60px;
  background: linear-gradient(transparent, var(--bg-void));
  pointer-events: none;
}

.sidebar__section {
  margin-bottom: var(--sp-6);
}

.sidebar__label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-ghost);
  padding: 0 var(--sp-5) var(--sp-2);
}

.sidebar__nav {
  list-style: none;
}

.sidebar__nav a {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-2) var(--sp-5);
  font-family: var(--font-body);
  font-size: 0.82rem;
  font-weight: 400;
  color: var(--text-secondary);
  letter-spacing: 0.01em;
  transition: color var(--t-fast), background var(--t-fast), border-color var(--t-fast);
  border-left: 2px solid transparent;
  position: relative;
}

.sidebar__nav a:hover {
  color: var(--text-primary);
  background: var(--border-subtle);
  border-left-color: var(--border-mid);
}

.sidebar__nav a.active {
  color: var(--accent);
  background: var(--accent-glow);
  border-left-color: var(--accent);
  font-weight: 500;
}

.nav-icon {
  font-size: 0.85rem;
  opacity: 0.7;
  flex-shrink: 0;
  width: 1rem;
  text-align: center;
}

.sidebar__nav a.active .nav-icon { opacity: 1; }

/* ── Main Content ─────────────────────────────────────────────────────────────── */

.main {
  grid-area: main;
  padding: var(--sp-8) var(--sp-10);
  max-width: 1100px;
  width: 100%;
}

/* ── Flash messages ──────────────────────────────────────────────────────────── */

.flash-list {
  list-style: none;
  margin-bottom: var(--sp-6);
}

.flash {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-3) var(--sp-4);
  font-family: var(--font-mono);
  font-size: 0.78rem;
  border-radius: var(--r-sm);
  border-left: 3px solid;
  margin-bottom: var(--sp-2);
}

.flash--success {
  background: rgba(30,102,64,0.12);
  border-color: var(--src-verified);
  color: #5ecb8a;
}

.flash--error {
  background: rgba(122,26,26,0.15);
  border-color: var(--src-leaked);
  color: #e07070;
}

/* ── Page header ─────────────────────────────────────────────────────────────── */

.page-header {
  margin-bottom: var(--sp-8);
  padding-bottom: var(--sp-6);
  border-bottom: 1px solid var(--border-dim);
  position: relative;
}

/* Accent line under page header */
.page-header::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 48px;
  height: 2px;
  background: var(--accent);
}

.page-header__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
}

.page-header__title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.8rem;
  letter-spacing: -0.01em;
  color: var(--text-primary);
  line-height: 1.1;
  margin-bottom: var(--sp-2);
}

.page-header__sub {
  font-size: 0.875rem;
  color: var(--text-secondary);
  max-width: 560px;
  line-height: 1.65;
}

/* ── Stat cards ──────────────────────────────────────────────────────────────── */

.stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  gap: var(--sp-3);
  margin-bottom: var(--sp-8);
}

.stat-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  padding: var(--sp-4) var(--sp-5);
  position: relative;
  overflow: hidden;
  transition: border-color var(--t-mid);
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent-muted), transparent);
}

.stat-card:hover { border-color: var(--border-mid); }

.stat-card__value {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 2.2rem;
  color: var(--accent);
  line-height: 1;
  margin-bottom: var(--sp-1);
}

.stat-card__label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ── Section heading ──────────────────────────────────────────────────────────── */

.section-heading {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding-bottom: var(--sp-3);
  border-bottom: 1px solid var(--border-dim);
  margin-bottom: var(--sp-4);
}

/* ── Artifact cards (grid) ────────────────────────────────────────────────────── */

.artifact-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--sp-4);
  margin-bottom: var(--sp-8);
}

.artifact-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  overflow: hidden;
  transition: border-color var(--t-mid), transform var(--t-mid);
  display: flex;
  flex-direction: column;
}

.artifact-card:hover {
  border-color: var(--border-mid);
  transform: translateY(-1px);
}

.artifact-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
  background: var(--bg-elevated);
}

.artifact-card__type {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.artifact-card__body {
  padding: var(--sp-4);
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.artifact-card__title {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.35;
}

.artifact-card__title a { color: inherit; }
.artifact-card__title a:hover { color: var(--accent); }

.artifact-card__event {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  margin-top: auto;
  padding-top: var(--sp-2);
}

.artifact-card__event a { color: var(--text-secondary); }
.artifact-card__event a:hover { color: var(--accent); }

.artifact-card__date {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-dim);
}

/* ── Event list ───────────────────────────────────────────────────────────────── */

.event-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.event-row {
  display: grid;
  grid-template-columns: 100px 1fr auto;
  gap: var(--sp-4);
  align-items: start;
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  padding: var(--sp-4) var(--sp-5);
  transition: border-color var(--t-mid), background var(--t-fast);
  position: relative;
}

.event-row:hover {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

/* Left accent bar on hover */
.event-row::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 2px;
  background: transparent;
  border-radius: var(--r-sm) 0 0 var(--r-sm);
  transition: background var(--t-mid);
}

.event-row:hover::before { background: var(--accent); }

.event-row__date {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  padding-top: 2px;
}

.event-row__title {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.35;
  margin-bottom: var(--sp-2);
}

.event-row__title a { color: inherit; }
.event-row__title a:hover { color: var(--accent); }

.event-row__summary {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.event-row__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--sp-2);
  flex-shrink: 0;
}

.event-row__location {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-dim);
}

.event-row__count {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-dim);
  background: var(--bg-overlay);
  padding: 2px 8px;
  border-radius: 2px;
  border: 1px solid var(--border-dim);
}

/* ── Filter bar ────────────────────────────────────────────────────────────────── */

.filter-bar {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
  margin-bottom: var(--sp-6);
  padding-bottom: var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
}

.filter-bar__label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-right: var(--sp-2);
}

.filter-bar__right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: var(--sp-2);
}

.filter-pill {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.04em;
  padding: var(--sp-1) var(--sp-3);
  border: 1px solid var(--border-mid);
  border-radius: var(--r-sm);
  color: var(--text-secondary);
  background: transparent;
  transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
  white-space: nowrap;
}

.filter-pill:hover {
  background: var(--bg-overlay);
  color: var(--text-primary);
  border-color: var(--border-bright);
}

.filter-pill.active {
  background: var(--accent-glow);
  color: var(--accent);
  border-color: var(--accent-muted);
}

/* Sort select */
.sort-select {
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 0.68rem;
  padding: var(--sp-1) var(--sp-3);
  border-radius: var(--r-sm);
  cursor: pointer;
  outline: none;
  transition: border-color var(--t-fast);
}

.sort-select:focus { border-color: var(--accent-muted); }
.sort-select option { background: var(--bg-elevated); }

/* ── Badges ────────────────────────────────────────────────────────────────────── */

.source-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: var(--r-sm);
  font-weight: 500;
  white-space: nowrap;
}

.source-badge--verified    { background: var(--src-verified-bg);    color: #5ecb8a; border: 1px solid var(--src-verified); }
.source-badge--unverified  { background: var(--src-unverified-bg);  color: #d4943a; border: 1px solid var(--src-unverified); }
.source-badge--government  { background: var(--src-government-bg);  color: #6a9de0; border: 1px solid var(--src-government); }
.source-badge--leaked      { background: var(--src-leaked-bg);      color: #e06060; border: 1px solid var(--src-leaked); }
.source-badge--citizen     { background: var(--src-citizen-bg);     color: #8aaabb; border: 1px solid var(--src-citizen); }
.source-badge--media       { background: var(--src-media-bg);       color: #5a9ec0; border: 1px solid var(--src-media); }

/* ── Phase 15.5: FORAGE ingestion source badges ─────────────────────────── */
/* GDELT — indigo / electric violet */
.source-badge--gdelt {
  background: rgba(99, 102, 241, 0.12);
  color:       #818cf8;
  border:      1px solid rgba(99, 102, 241, 0.35);
}
.source-badge--gdelt:hover {
  background: rgba(99, 102, 241, 0.20);
}

/* GDACS — emerald / natural-disaster green */
.source-badge--gdacs {
  background: rgba(16, 185, 129, 0.10);
  color:       #34d399;
  border:      1px solid rgba(16, 185, 129, 0.30);
}
.source-badge--gdacs:hover {
  background: rgba(16, 185, 129, 0.18);
}

/* RSS — amber, matching existing accent */
.source-badge--rss {
  background: rgba(200, 148, 58, 0.10);
  color:       var(--accent);
  border:      1px solid rgba(200, 148, 58, 0.30);
}

/* Interpol — warm amber-orange */
.source-badge--interpol {
  background: rgba(245, 158, 11, 0.10);
  color:       #fbbf24;
  border:      1px solid rgba(245, 158, 11, 0.30);
}

/* Generic unknown source */
.source-badge--unknown,
.source-badge--gdelt_doc,
.source-badge--other {
  background: rgba(255,255,255,0.04);
  color:       var(--text-dim);
  border:      1px solid rgba(255,255,255,0.08);
}

/* Count pill inside summary bar source badges */
.source-badge__count {
  display:         inline-block;
  margin-left:     4px;
  padding:         0 4px;
  background:      rgba(255,255,255,0.08);
  border-radius:   3px;
  font-size:       0.65em;
  font-family:     var(--font-mono);
  letter-spacing:  0;
  vertical-align:  middle;
}

.category-badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: var(--r-sm);
  background: var(--bg-overlay);
  color: var(--text-secondary);
  border: 1px solid var(--border-dim);
}

.type-badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: var(--r-sm);
  background: var(--bg-elevated);
  color: var(--text-dim);
  border: 1px solid var(--border-dim);
}

.actor-type-badge {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  padding: 2px 7px;
  border-radius: var(--r-sm);
}

/* ── Breakdown bar ─────────────────────────────────────────────────────────────── */

.breakdown-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  margin-bottom: var(--sp-8);
}

.breakdown-item {
  display: grid;
  grid-template-columns: 80px 1fr 40px;
  align-items: center;
  gap: var(--sp-3);
}

.breakdown-item__label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

.breakdown-item__bar-track {
  height: 4px;
  background: var(--bg-overlay);
  border-radius: 2px;
  overflow: hidden;
}

.breakdown-item__bar {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-muted), var(--accent));
  border-radius: 2px;
  transition: width 600ms cubic-bezier(0.4, 0, 0.2, 1);
}

.breakdown-item__count {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  text-align: right;
}

/* ── Actors grid ───────────────────────────────────────────────────────────────── */

.actor-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: var(--sp-4);
}

.actor-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  padding: var(--sp-5);
  transition: border-color var(--t-mid), transform var(--t-mid);
  position: relative;
  overflow: hidden;
}

.actor-card:hover {
  border-color: var(--border-mid);
  transform: translateY(-1px);
}

/* Node indicator — top-right corner */
.actor-card::after {
  content: '◉';
  position: absolute;
  top: var(--sp-4);
  right: var(--sp-4);
  font-size: 0.65rem;
  color: var(--text-ghost);
}

.actor-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--sp-3);
  margin-bottom: var(--sp-3);
}

.actor-card__name {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.3;
}

.actor-card__name a { color: inherit; }
.actor-card__name a:hover { color: var(--accent); }

.actor-card__desc {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: var(--sp-4);
}

.actor-card__stats {
  display: flex;
  gap: var(--sp-4);
  padding-top: var(--sp-3);
  border-top: 1px solid var(--border-dim);
}

.actor-card__stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.actor-card__stat-value {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.2rem;
  color: var(--accent);
  line-height: 1;
}

.actor-card__stat-label {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ── Search ─────────────────────────────────────────────────────────────────────── */

.search-header {
  margin-bottom: var(--sp-8);
}

.search-form {
  display: flex;
  max-width: 640px;
  margin-bottom: var(--sp-4);
}

.search-form input {
  flex: 1;
  background: var(--bg-elevated);
  border: 1px solid var(--border-mid);
  border-right: none;
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 0.875rem;
  padding: var(--sp-3) var(--sp-4);
  border-radius: var(--r-sm) 0 0 var(--r-sm);
  outline: none;
  transition: border-color var(--t-fast), background var(--t-fast);
}

.search-form input:focus {
  border-color: var(--accent-muted);
  background: var(--bg-overlay);
}

.search-form input::placeholder { color: var(--text-dim); }

.search-form button {
  background: var(--accent-muted);
  border: 1px solid var(--accent-muted);
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 0.78rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: var(--sp-3) var(--sp-5);
  cursor: pointer;
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
  transition: background var(--t-fast), color var(--t-fast);
}

.search-form button:hover {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg-void);
}

.search-summary {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-secondary);
}

.search-result {
  border-bottom: 1px solid var(--border-dim);
  padding: var(--sp-4) 0;
}

.search-result:last-child { border-bottom: none; }

.search-result__kind {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
}

.search-result__title {
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--sp-2);
  line-height: 1.35;
}

.search-result__title a { color: inherit; }
.search-result__title a:hover { color: var(--accent); }

.search-result__excerpt {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--sp-2);
  max-width: 680px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.search-result__meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-3);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-dim);
}

.search-result__meta a { color: var(--text-secondary); }
.search-result__meta a:hover { color: var(--accent); }

/* ── Empty state ──────────────────────────────────────────────────────────────────── */

.empty-state {
  text-align: center;
  padding: var(--sp-16) var(--sp-8);
  color: var(--text-dim);
  font-family: var(--font-mono);
  font-size: 0.78rem;
  line-height: 2;
}

.empty-state a { color: var(--text-secondary); }
.empty-state a:hover { color: var(--accent); }

/* ── Admin panel ──────────────────────────────────────────────────────────────────── */

.admin-layout {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: var(--sp-8);
  align-items: start;
}

.form-panel {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  overflow: hidden;
  margin-bottom: var(--sp-6);
}

.form-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-3) var(--sp-5);
  background: var(--bg-elevated);
  border-bottom: 1px solid var(--border-dim);
}

.form-panel__title {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

.form-panel__body {
  padding: var(--sp-5);
}

/* Form elements */
.form-row {
  margin-bottom: var(--sp-4);
}

.form-row--double {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-4);
}

label {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-1);
}

label .required {
  color: var(--accent-muted);
  margin-left: 2px;
}

input[type="text"],
input[type="search"],
input[type="date"],
input[type="number"],
input[type="password"],
select,
textarea {
  width: 100%;
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  color: var(--text-primary);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  padding: var(--sp-2) var(--sp-3);
  outline: none;
  transition: border-color var(--t-fast), background var(--t-fast);
  -webkit-appearance: none;
}

input:focus, select:focus, textarea:focus {
  border-color: var(--accent-muted);
  background: var(--bg-overlay);
}

input::placeholder, textarea::placeholder { color: var(--text-dim); }

select option { background: var(--bg-elevated); }

textarea {
  resize: vertical;
  min-height: 90px;
  line-height: 1.55;
  font-family: var(--font-body);
  font-size: 0.8rem;
}

input[type="file"] {
  font-size: 0.75rem;
  color: var(--text-secondary);
  cursor: pointer;
  padding: var(--sp-2) 0;
  border: none;
  background: none;
}

input[type="file"]::file-selector-button {
  background: var(--bg-overlay);
  border: 1px solid var(--border-mid);
  color: var(--text-secondary);
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: var(--sp-2) var(--sp-3);
  border-radius: var(--r-sm);
  cursor: pointer;
  margin-right: var(--sp-3);
  transition: background var(--t-fast), color var(--t-fast);
}

input[type="file"]::file-selector-button:hover {
  background: var(--accent-glow);
  color: var(--accent);
  border-color: var(--accent-muted);
}

.form-hint {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--text-dim);
  margin-top: 4px;
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: var(--sp-2) var(--sp-5);
  border-radius: var(--r-sm);
  border: 1px solid;
  cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
  white-space: nowrap;
}

.btn--primary {
  background: var(--accent-muted);
  border-color: var(--accent-muted);
  color: var(--text-primary);
}

.btn--primary:hover {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg-void);
}

.btn--ghost {
  background: transparent;
  border-color: var(--border-mid);
  color: var(--text-secondary);
}

.btn--ghost:hover {
  background: var(--bg-overlay);
  border-color: var(--border-bright);
  color: var(--text-primary);
}

/* Admin log table */
.log-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.78rem;
}

.log-table th {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding: var(--sp-2) var(--sp-3);
  text-align: left;
  border-bottom: 1px solid var(--border-dim);
  }

.log-table td {
  padding: var(--sp-2) var(--sp-3);
  border-bottom: 1px solid var(--border-dim);
  vertical-align: middle;
  color: var(--text-secondary);
}

.log-table tr:last-child td { border-bottom: none; }
.log-table tr:hover td { background: var(--bg-elevated); }

/* ── Divider ──────────────────────────────────────────────────────────────────── */
.divider {
  border: none;
  border-top: 1px solid var(--border-dim);
  margin: var(--sp-4) 0;
}

/* ============================================================================
   PHASE 4 — Relationship Clustering & Narrative Chains
   Detail page components: Circle of Evidence, Narrative Chain, Co-Actor
   Network, Role Timeline, Artifact Footprint, Breadcrumb, etc.
   ============================================================================ */

/* ── Breadcrumb ─────────────────────────────────────────────────────────────── */

.breadcrumb {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-1);
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-dim);
  margin-bottom: var(--sp-6);
}

.breadcrumb a { color: var(--text-secondary); }
.breadcrumb a:hover { color: var(--accent); }

.breadcrumb__sep {
  color: var(--text-ghost);
  margin: 0 var(--sp-1);
}

.breadcrumb__current { color: var(--text-dim); }

/* ── Detail layout (main + sidebar) ────────────────────────────────────────── */

.detail-layout {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: var(--sp-8);
  align-items: start;
}

.detail-layout__main {
  min-width: 0;
}

.detail-layout__sidebar {
  position: sticky;
  top: calc(var(--topbar-h) + var(--sp-6));
}

/* ── Detail section ─────────────────────────────────────────────────────────── */

.detail-section {
  margin-bottom: var(--sp-10);
}

.detail-section__title {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding-bottom: var(--sp-3);
  border-bottom: 1px solid var(--border-dim);
  margin-bottom: var(--sp-4);
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}

.detail-section__count {
  background: var(--bg-overlay);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: 1px 7px;
  font-size: 0.6rem;
  color: var(--accent);
}

.detail-section__desc {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--sp-4);
  max-width: 580px;
}

/* ── Body text ───────────────────────────────────────────────────────────────── */

.detail-body-text {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  max-width: 680px;
}

/* ── Meta panel (sidebar card) ──────────────────────────────────────────────── */

.meta-panel {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  overflow: hidden;
}

.meta-panel__header {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding: var(--sp-3) var(--sp-4);
  background: var(--bg-elevated);
  border-bottom: 1px solid var(--border-dim);
}

.meta-panel__body {
  padding: var(--sp-4);
}

.meta-field {
  margin-bottom: var(--sp-4);
}

.meta-field:last-child { margin-bottom: 0; }

.meta-field__label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 3px;
}

.meta-field__value {
  font-size: 0.85rem;
  color: var(--text-primary);
  line-height: 1.4;
}

/* ── Tag cloud ───────────────────────────────────────────────────────────────── */

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-1);
}

.tag-pill {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.04em;
  padding: 2px 8px;
  border: 1px solid var(--border-dim);
  border-radius: 2px;
  color: var(--text-secondary);
  background: var(--bg-elevated);
  transition: border-color var(--t-fast), color var(--t-fast), background var(--t-fast);
}

.tag-pill:hover {
  border-color: var(--accent-muted);
  color: var(--accent);
  background: var(--accent-glow);
}

/* ── Provenance chain ───────────────────────────────────────────────────────── */

.chain {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.chain__node {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-2) 0;
}

.chain__icon {
  font-size: 0.75rem;
  width: 1rem;
  text-align: center;
  flex-shrink: 0;
  color: var(--text-dim);
}

.chain__label {
  font-size: 0.78rem;
  color: var(--text-secondary);
}

.chain__label--link {
  color: var(--accent);
}

.chain__label--link:hover { color: var(--accent-bright); }

.chain__connector {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-ghost);
  padding-left: 0.45rem;
  line-height: 0.8;
}

/* ── Event summary block ────────────────────────────────────────────────────── */

.event-summary-block {
  display: flex;
  gap: var(--sp-5);
  margin-bottom: var(--sp-8);
  max-width: 760px;
}

.event-summary-block__rule {
  width: 2px;
  background: var(--accent-muted);
  border-radius: 1px;
  flex-shrink: 0;
  align-self: stretch;
  min-height: 20px;
}

.event-summary-block__text {
  font-size: 0.95rem;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ── Event stat row ─────────────────────────────────────────────────────────── */

.event-stat-row {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  padding: var(--sp-4) var(--sp-6);
  margin-bottom: var(--sp-8);
  flex-wrap: wrap;
}

.event-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  flex: 1;
  min-width: 80px;
}

.event-stat__value {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.6rem;
  color: var(--accent);
  line-height: 1;
}

.event-stat__label {
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.event-stat-divider {
  width: 1px;
  height: 32px;
  background: var(--border-dim);
  flex-shrink: 0;
  margin: 0 var(--sp-4);
}

/* ── Actor role list ─────────────────────────────────────────────────────────── */

.actor-role-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
}

.actor-role-row {
  display: flex;
  gap: var(--sp-4);
  padding: var(--sp-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  transition: border-color var(--t-mid), background var(--t-fast);
}

.actor-role-row:hover {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

.actor-role-row__indicator {
  font-size: 0.9rem;
  flex-shrink: 0;
  width: 1.2rem;
  text-align: center;
  padding-top: 2px;
  color: var(--text-dim);
}

.actor-role-row__indicator--person     { color: #8ab4c8; }
.actor-role-row__indicator--government { color: #6a9de0; }
.actor-role-row__indicator--institution{ color: var(--accent-muted); }
.actor-role-row__indicator--movement   { color: #8a9a6a; }
.actor-role-row__indicator--media      { color: #6a8aaa; }

.actor-role-row__body {
  flex: 1;
  min-width: 0;
}

.actor-role-row__top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-2);
  margin-bottom: var(--sp-2);
}

.actor-role-row__name {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-primary);
}

.actor-role-row__name:hover { color: var(--accent); }

.actor-role-row__role {
  margin-bottom: var(--sp-2);
}

.actor-role-row__desc {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ── Role badge ──────────────────────────────────────────────────────────────── */

.role-badge {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.05em;
  padding: 2px 8px;
  border-radius: var(--r-sm);
  background: rgba(200, 148, 58, 0.08);
  border: 1px solid var(--accent-muted);
  color: var(--accent);
  white-space: nowrap;
}

.role-badge--event {
  background: rgba(200, 148, 58, 0.12);
}

.role-badge--timeline {
  background: rgba(200, 148, 58, 0.06);
  border-color: rgba(200, 148, 58, 0.3);
}

/* ── Source breakdown ────────────────────────────────────────────────────────── */

.source-breakdown {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2);
  margin-bottom: var(--sp-4);
  padding: var(--sp-3) var(--sp-4);
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
}

.source-breakdown__item {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
}

.source-breakdown__count {
  font-size: 0.7rem;
  color: var(--text-dim);
}

/* ── Evidence list ───────────────────────────────────────────────────────────── */

.evidence-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
}

.evidence-row {
  display: grid;
  grid-template-columns: 72px 1fr auto;
  gap: var(--sp-4);
  align-items: center;
  padding: var(--sp-3) var(--sp-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  transition: border-color var(--t-fast), background var(--t-fast);
  text-decoration: none;
  color: inherit;
  position: relative;
}

.evidence-row:hover {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

.evidence-row::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: transparent;
  border-radius: var(--r-sm) 0 0 var(--r-sm);
  transition: background var(--t-mid);
}

.evidence-row:hover::before { background: var(--accent); }

.evidence-row--compact { padding: var(--sp-2) var(--sp-3); }

.evidence-row__type-col {
  display: flex;
  align-items: center;
}

.evidence-row__body { min-width: 0; }

.evidence-row__title {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.evidence-row__desc {
  font-size: 0.75rem;
  color: var(--text-secondary);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.evidence-row__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 3px;
  flex-shrink: 0;
}

/* ── Narrative chain (related events by shared actor) ───────────────────────── */

.narrative-chain {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.chain-event-card {
  display: grid;
  grid-template-columns: 100px 1fr 50px;
  gap: var(--sp-4);
  align-items: start;
  padding: var(--sp-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--t-mid), background var(--t-fast);
  position: relative;
}

.chain-event-card:hover {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

/* Amber thread line on left */
.chain-event-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: transparent;
  border-radius: var(--r-sm) 0 0 var(--r-sm);
  transition: background var(--t-mid);
}

.chain-event-card:hover::before { background: var(--accent); }

.chain-event-card__left {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.chain-event-card__date {
  font-size: 0.68rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

.chain-event-card__body { min-width: 0; }

.chain-event-card__title {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--sp-2);
  line-height: 1.3;
}

.chain-event-card__shared {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-2);
  margin-bottom: var(--sp-1);
}

.chain-shared-actor {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--accent);
  background: var(--accent-glow);
  border: 1px solid var(--accent-muted);
  border-radius: var(--r-sm);
  padding: 1px 6px;
}

.chain-event-card__location {
  font-size: 0.65rem;
  color: var(--text-dim);
}

.chain-event-card__link-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  background: var(--bg-overlay);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-2);
  text-align: center;
}

/* ── Circle of Evidence ─────────────────────────────────────────────────────── */

.circle-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: var(--sp-3);
}

.circle-card {
  display: flex;
  gap: var(--sp-3);
  padding: var(--sp-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--t-mid), background var(--t-fast);
  align-items: flex-start;
}

.circle-card:hover {
  border-color: var(--accent-muted);
  background: var(--accent-glow);
}

.circle-card__node {
  font-size: 0.9rem;
  color: var(--accent-muted);
  flex-shrink: 0;
  transition: color var(--t-fast);
  padding-top: 1px;
}

.circle-card:hover .circle-card__node { color: var(--accent); }

.circle-card__body { min-width: 0; }

.circle-card__type {
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 2px;
}

.circle-card__name {
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: var(--sp-2);
}

.circle-card__role { margin-top: var(--sp-1); }

/* ── Sibling / related rows ─────────────────────────────────────────────────── */

.sibling-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.sibling-row {
  display: grid;
  grid-template-columns: 72px 1fr auto 20px;
  gap: var(--sp-3);
  align-items: center;
  padding: var(--sp-3) var(--sp-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--t-fast), background var(--t-fast);
}

.sibling-row:hover {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

.sibling-row__type {
  font-size: 0.62rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.sibling-row__title {
  font-size: 0.85rem;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sibling-row__meta {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-shrink: 0;
}

.sibling-row__arrow {
  color: var(--text-ghost);
  font-family: var(--font-mono);
  transition: color var(--t-fast);
}

.sibling-row:hover .sibling-row__arrow { color: var(--accent); }

/* ── Related grid (tag-based) ────────────────────────────────────────────────── */

.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: var(--sp-3);
}

.related-card {
  padding: var(--sp-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--t-mid), background var(--t-fast);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.related-card:hover {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

.related-card__type {
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.related-card__title {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.35;
}

.related-card__event {
  font-size: 0.68rem;
  color: var(--text-dim);
  margin-top: auto;
}

/* ── Event link card (parent event on artifact page) ─────────────────────────── */

.event-link-card {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  padding: var(--sp-5);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--t-mid), background var(--t-fast);
  gap: var(--sp-4);
}

.event-link-card:hover {
  border-color: var(--accent-muted);
  background: var(--accent-glow-lg, rgba(200,148,58,0.04));
}

.event-link-card__left { flex: 1; min-width: 0; }

.event-link-card__label {
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
}

.event-link-card__title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--sp-2);
  line-height: 1.3;
}

.event-link-card__location {
  font-size: 0.68rem;
  color: var(--text-dim);
  margin-bottom: var(--sp-3);
}

.event-link-card__summary {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.6;
}

.event-link-card__arrow {
  font-family: var(--font-mono);
  font-size: 1rem;
  color: var(--text-ghost);
  align-self: center;
  transition: color var(--t-fast), transform var(--t-fast);
}

.event-link-card:hover .event-link-card__arrow {
  color: var(--accent);
  transform: translateX(3px);
}

/* ── Media viewer ────────────────────────────────────────────────────────────── */

.media-viewer {
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  overflow: hidden;
}

.media-viewer__image {
  display: block;
  width: 100%;
  height: auto;
  max-height: 600px;
  object-fit: contain;
  background: var(--bg-void);
}

.media-viewer__video {
  display: block;
  width: 100%;
  max-height: 480px;
  background: var(--bg-void);
}

.media-viewer__audio-wrap {
  padding: var(--sp-6);
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
}

.media-viewer__audio-label {
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  text-transform: uppercase;
}

.media-viewer__audio {
  width: 100%;
  filter: invert(1) hue-rotate(180deg) brightness(0.7);
}

.media-viewer__doc {
  padding: var(--sp-8);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-4);
  text-align: center;
}

.media-viewer__doc-icon {
  font-size: 2.5rem;
  color: var(--text-ghost);
}

.media-viewer__doc-name {
  font-size: 0.75rem;
  color: var(--text-secondary);
  word-break: break-all;
}

/* ── Role timeline (actor page) ─────────────────────────────────────────────── */

.role-timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.role-timeline__item {
  display: flex;
  gap: var(--sp-4);
}

.role-timeline__spine {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  padding-top: 4px;
}

.role-timeline__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  border: 2px solid var(--accent-muted);
  background: var(--bg-base);
  flex-shrink: 0;
  transition: border-color var(--t-fast), background var(--t-fast);
}

.role-timeline__item:hover .role-timeline__dot {
  border-color: var(--accent);
  background: var(--accent-glow);
}

.role-timeline__line {
  width: 1px;
  flex: 1;
  min-height: 24px;
  background: var(--border-dim);
  margin: 4px 0;
}

.role-timeline__body {
  padding-bottom: var(--sp-5);
  flex: 1;
  min-width: 0;
}

.role-timeline__date {
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  margin-bottom: 3px;
}

.role-timeline__event {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--sp-2);
  line-height: 1.3;
}

.role-timeline__event a { color: inherit; }
.role-timeline__event a:hover { color: var(--accent); }

.role-timeline__role { }

/* ── Event row (with role support) ─────────────────────────────────────────── */

.event-row__content { min-width: 0; }

.event-row__role {
  margin-bottom: var(--sp-2);
  margin-top: var(--sp-1);
}

/* ── Footprint event group ───────────────────────────────────────────────────── */

.footprint-event-group {
  margin-bottom: var(--sp-5);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  overflow: hidden;
}

.footprint-event-group__header {
  padding: var(--sp-3) var(--sp-4);
  background: var(--bg-elevated);
  border-bottom: 1px solid var(--border-dim);
}

.footprint-event-group__title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.06em;
  color: var(--text-secondary);
}

.footprint-event-group__title:hover { color: var(--accent); }

.footprint-event-group__items .evidence-row {
  border: none;
  border-bottom: 1px solid var(--border-dim);
  border-radius: 0;
}

.footprint-event-group__items .evidence-row:last-child {
  border-bottom: none;
}

.footprint-event-group__items .evidence-row::before {
  border-radius: 0;
}

/* ── Co-actor grid ───────────────────────────────────────────────────────────── */

.co-actor-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: var(--sp-3);
}

.co-actor-card {
  padding: var(--sp-4);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  text-decoration: none;
  color: inherit;
  transition: border-color var(--t-mid), background var(--t-fast);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.co-actor-card:hover {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

.co-actor-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.co-actor-card__overlap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1px;
}

.co-actor-card__name {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.3;
}

.co-actor-card__events {
  display: flex;
  flex-direction: column;
  gap: 2px;
  font-size: 0.65rem;
  color: var(--text-dim);
  margin-top: var(--sp-1);
}

/* ── Responsive ──────────────────────────────────────────────────────────────── */

@media (max-width: 900px) {
  .detail-layout {
    grid-template-columns: 1fr;
  }

  .detail-layout__sidebar {
    position: static;
    order: -1;
  }

  .event-stat-row {
    gap: var(--sp-4);
  }

  .chain-event-card {
    grid-template-columns: 90px 1fr;
  }

  .chain-event-card__link-count { display: none; }
}

@media (max-width: 700px) {
  .shell {
    grid-template-columns: 1fr;
    grid-template-areas:
      "topbar"
      "main";
  }

  .sidebar { display: none; }

  .main {
    padding: var(--sp-6) var(--sp-4);
  }

  .evidence-row {
    grid-template-columns: 60px 1fr;
  }

  .evidence-row__meta { display: none; }

  .sibling-row {
    grid-template-columns: 60px 1fr 20px;
  }

  .sibling-row__meta { display: none; }
}

/* ============================================================================
   PHASE 5 — Timeline Explorer & Map Explorer
   ============================================================================ */

/* ── Timeline span bar ──────────────────────────────────────────────────────── */

.timeline-span-bar {
  display: grid;
  grid-template-columns: 130px 1fr 130px;
  align-items: center;
  gap: var(--sp-4);
  margin-bottom: var(--sp-8);
  padding: var(--sp-4) var(--sp-5);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
}

.timeline-span-bar__item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.timeline-span-bar__item--right {
  align-items: flex-end;
  text-align: right;
}

.timeline-span-bar__value {
  font-size: 0.82rem;
  color: var(--accent);
  letter-spacing: 0.04em;
}

.timeline-span-bar__label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.timeline-span-bar__track {
  position: relative;
  height: 3px;
  background: var(--bg-overlay);
  border-radius: 2px;
  overflow: visible;
}

.timeline-span-bar__fill {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, var(--accent-muted), var(--accent));
  border-radius: 2px;
  animation: fillBar 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes fillBar {
  from { width: 0; }
  to   { width: 100%; }
}

.timeline-span-bar__label-center {
  position: absolute;
  top: 8px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
  white-space: nowrap;
}

/* ── Timeline legend ────────────────────────────────────────────────────────── */

.timeline-legend {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-4);
  margin-bottom: var(--sp-8);
  padding-bottom: var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
}

.timeline-legend__item {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

.timeline-legend__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* Category dot colours */
.timeline-legend__dot--election      { background: #6a4aaa; }
.timeline-legend__dot--security      { background: #c04040; }
.timeline-legend__dot--civil-unrest  { background: #c07830; }
.timeline-legend__dot--legislative   { background: #3a70c0; }
.timeline-legend__dot--economic      { background: #3a9060; }
.timeline-legend__dot--diplomatic    { background: #7a5a9a; }
.timeline-legend__dot--military      { background: #8a2020; }
.timeline-legend__dot--social        { background: #4a7a6a; }
.timeline-legend__dot--other         { background: #4a5a6a; }

/* ── Timeline scaffold ──────────────────────────────────────────────────────── */

.tl {
  position: relative;
  padding: 0 0 var(--sp-12) 0;
  /* Centre the spine in the middle of the content column */
}

/* Vertical spine running through the centre */
.tl__spine {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 1px;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    var(--border-mid) 5%,
    var(--border-mid) 95%,
    transparent 100%
  );
  z-index: 0;
}

/* ── Year marker ────────────────────────────────────────────────────────────── */

.tl__year-marker {
  position: relative;
  display: flex;
  justify-content: center;
  margin: var(--sp-8) 0 var(--sp-6);
  z-index: 2;
}

.tl__year-badge {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: 0.08em;
  color: var(--text-primary);
  background: var(--bg-base);
  border: 1px solid var(--border-mid);
  border-radius: var(--r-sm);
  padding: var(--sp-2) var(--sp-5);
  position: relative;
  z-index: 2;
}

.tl__year-badge::before,
.tl__year-badge::after {
  content: '';
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40px;
  height: 1px;
  background: var(--border-mid);
}

.tl__year-badge::before { right: 100%; margin-right: 4px; }
.tl__year-badge::after  { left:  100%; margin-left:  4px; }

.tl__year-badge--undated {
  font-family: var(--font-mono);
  font-weight: 400;
  font-size: 0.75rem;
  color: var(--text-dim);
  border-style: dashed;
}

/* ── Month label ────────────────────────────────────────────────────────────── */

.tl__month-group {
  position: relative;
  margin-bottom: var(--sp-4);
}

.tl__month-label {
  position: relative;
  z-index: 2;
  display: block;
  text-align: center;
  font-size: 0.62rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-4);
  background: var(--bg-base);
  width: fit-content;
  margin-left: auto;
  margin-right: auto;
  padding: 0 var(--sp-3);
}

/* ── Timeline entry ─────────────────────────────────────────────────────────── */

.tl__entry {
  position: relative;
  display: grid;
  margin-bottom: var(--sp-5);
  z-index: 1;
}

/* Left entry: card on left, connector + node on right half */
.tl__entry--left {
  grid-template-columns: calc(50% - 30px) 60px 1fr;
  grid-template-areas: "card connector node-space";
}

/* Right entry: card on right, connector + node on left half */
.tl__entry--right {
  grid-template-columns: 1fr 60px calc(50% - 30px);
  grid-template-areas: "node-space connector card";
}

.tl__entry--left  .tl__card       { grid-area: card; }
.tl__entry--right .tl__card       { grid-area: card; }
.tl__entry--left  .tl__connector  { grid-area: connector; }
.tl__entry--right .tl__connector  { grid-area: connector; }

/* ── Spine node ─────────────────────────────────────────────────────────────── */

.tl__node {
  position: absolute;
  /* Centre on the spine */
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 14px;
  height: 14px;
  border-radius: 50%;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform var(--t-mid), box-shadow var(--t-mid);
}

.tl__entry:hover .tl__node {
  transform: translate(-50%, -50%) scale(1.4);
}

.tl__node-inner {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

/* Node colour by category */
.tl__node--election    { background: rgba(106,74,170,0.3); border: 2px solid #6a4aaa; box-shadow: 0 0 8px rgba(106,74,170,0.4); }
.tl__node--election    .tl__node-inner { background: #6a4aaa; }

.tl__node--security    { background: rgba(192,64,64,0.3);  border: 2px solid #c04040; box-shadow: 0 0 8px rgba(192,64,64,0.4); }
.tl__node--security    .tl__node-inner { background: #c04040; }

.tl__node--civil-unrest{ background: rgba(192,120,48,0.3); border: 2px solid #c07830; box-shadow: 0 0 8px rgba(192,120,48,0.4); }
.tl__node--civil-unrest .tl__node-inner { background: #c07830; }

.tl__node--legislative { background: rgba(58,112,192,0.3); border: 2px solid #3a70c0; box-shadow: 0 0 8px rgba(58,112,192,0.4); }
.tl__node--legislative .tl__node-inner { background: #3a70c0; }

.tl__node--other,
.tl__node--social,
.tl__node--economic    { background: rgba(74,90,106,0.3);  border: 2px solid #4a5a6a; box-shadow: 0 0 8px rgba(74,90,106,0.4); }
.tl__node--other .tl__node-inner,
.tl__node--social .tl__node-inner,
.tl__node--economic .tl__node-inner { background: #4a5a6a; }

/* ── Connector arm ──────────────────────────────────────────────────────────── */

.tl__connector {
  align-self: center;
  height: 1px;
  background: var(--border-dim);
  transition: background var(--t-mid);
}

.tl__entry:hover .tl__connector { background: var(--border-mid); }

/* ── Timeline card ──────────────────────────────────────────────────────────── */

.tl__card {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-md);
  padding: var(--sp-4) var(--sp-5);
  transition: border-color var(--t-mid), background var(--t-fast),
              transform var(--t-mid), box-shadow var(--t-mid);
  position: relative;
  overflow: hidden;
}

.tl__card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent-muted), transparent);
  opacity: 0;
  transition: opacity var(--t-mid);
}

.tl__entry:hover .tl__card {
  border-color: var(--border-mid);
  background: var(--bg-elevated);
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}

.tl__entry:hover .tl__card::before { opacity: 1; }

/* Right-side cards have the accent on the right edge */
.tl__card--right::before {
  background: linear-gradient(270deg, var(--accent-muted), transparent);
}

.tl__card-header {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
  margin-bottom: var(--sp-3);
}

.tl__date-badge {
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  color: var(--accent);
  background: var(--accent-glow);
  border: 1px solid var(--accent-muted);
  padding: 2px 8px;
  border-radius: var(--r-sm);
}

.tl__date-badge--unknown {
  color: var(--text-dim);
  background: transparent;
  border-color: var(--border-dim);
}

/* Override category-badge inside timeline */
.tl__cat-badge { }

.tl__card-title {
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 0.9rem;
  line-height: 1.35;
  color: var(--text-primary);
  margin-bottom: var(--sp-2);
}

.tl__card-title a { color: inherit; }
.tl__card-title a:hover { color: var(--accent); }

.tl__card-location {
  font-size: 0.65rem;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
  letter-spacing: 0.04em;
}

.tl__card-summary {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--sp-3);
}

.tl__card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--sp-2);
  border-top: 1px solid var(--border-dim);
}

.tl__artifact-count {
  font-size: 0.62rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.tl__card-link {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  color: var(--accent);
  transition: color var(--t-fast), letter-spacing var(--t-fast);
}

.tl__card-link:hover {
  color: var(--accent-bright);
  letter-spacing: 0.1em;
}

/* ── Timeline terminal ──────────────────────────────────────────────────────── */

.tl__terminal {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-3);
  padding-top: var(--sp-6);
  z-index: 2;
}

.tl__terminal-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  border: 2px solid var(--border-mid);
  background: var(--bg-base);
  animation: pulse 2.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(200,148,58,0.3); }
  50%       { box-shadow: 0 0 0 6px rgba(200,148,58,0); }
}

.tl__terminal-label {
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ── Timeline responsive ────────────────────────────────────────────────────── */

@media (max-width: 860px) {
  /* Collapse to left-spine single column */
  .tl__spine {
    left: 24px;
    transform: none;
  }

  .tl__entry--left,
  .tl__entry--right {
    grid-template-columns: 48px 1fr;
    grid-template-areas: "connector card";
  }

  .tl__node {
    left: 24px;
  }

  .tl__year-marker { justify-content: flex-start; padding-left: 60px; }
  .tl__year-badge::before { display: none; }
  .tl__year-badge::after  { width: 100px; left: 100%; }

  .tl__month-label { margin-left: 60px; margin-right: auto; }

  .tl__terminal { align-items: flex-start; padding-left: 60px; }
}

/* ═══════════════════════════════════════════════════════════════════════════
   MAP EXPLORER
   ═══════════════════════════════════════════════════════════════════════════ */

/* Map container fills remaining viewport height */
#forge-map {
  position: fixed;
  top: var(--topbar-h);
  left: var(--sidebar-w);
  right: 0;
  /* Reserve space for the header bar */
  bottom: 0;
  z-index: 1;
}

/* ── Map header bar ─────────────────────────────────────────────────────────── */

.map-header {
  position: fixed;
  top: var(--topbar-h);
  left: var(--sidebar-w);
  right: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-6);
  padding: var(--sp-3) var(--sp-6);
  background: rgba(8, 13, 18, 0.92);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--border-dim);
  flex-wrap: wrap;
}

/* Push map down to sit below the header */
#forge-map {
  top: calc(var(--topbar-h) + 64px);
}

.map-header__left { display: flex; flex-direction: column; gap: 2px; }
.map-header__left .breadcrumb { margin-bottom: 0; }

.map-header__title {
  display: flex;
  align-items: baseline;
  gap: var(--sp-3);
}

.map-header__wordmark {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1rem;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.map-header__meta {
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ── Map filter pills ───────────────────────────────────────────────────────── */

.map-header__filters {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
}

.map-filter-pill {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.04em;
  padding: var(--sp-1) var(--sp-3);
  border: 1px solid var(--border-mid);
  border-radius: var(--r-sm);
  color: var(--text-secondary);
  background: rgba(8,13,18,0.8);
  cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
  white-space: nowrap;
}

.map-filter-pill:hover {
  background: var(--bg-overlay);
  color: var(--text-primary);
  border-color: var(--border-bright);
}

.map-filter-pill--active {
  background: var(--accent-glow);
  color: var(--accent);
  border-color: var(--accent-muted);
}

/* ── Info panel (slide-in from right) ───────────────────────────────────────── */

.map-info-panel {
  position: fixed;
  right: 0;
  top: calc(var(--topbar-h) + 64px);
  bottom: 0;
  width: 340px;
  background: var(--bg-surface);
  border-left: 1px solid var(--border-dim);
  z-index: 600;
  transform: translateX(100%);
  transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.map-info-panel--open {
  transform: translateX(0);
}

.map-info-panel__close {
  position: absolute;
  top: var(--sp-3);
  right: var(--sp-3);
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-dim);
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  cursor: pointer;
  transition: color var(--t-fast), border-color var(--t-fast);
  z-index: 1;
}

.map-info-panel__close:hover {
  color: var(--text-primary);
  border-color: var(--border-mid);
}

.map-info-panel__content {
  flex: 1;
}

/* ── Map popup card (inside info panel) ─────────────────────────────────────── */

.map-popup__header {
  padding: var(--sp-5) var(--sp-5) var(--sp-4);
  border-left: 3px solid var(--accent); /* overridden by JS with category colour */
  border-bottom: 1px solid var(--border-dim);
  margin-left: -1px; /* align with panel border */
}

.map-popup__meta {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-bottom: var(--sp-2);
  flex-wrap: wrap;
}

.map-popup__meta .mono {
  font-size: 0.7rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

.map-popup__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1rem;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: var(--sp-2);
}

.map-popup__location {
  font-size: 0.68rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

.map-popup__body {
  padding: var(--sp-4) var(--sp-5);
  border-bottom: 1px solid var(--border-dim);
}

.map-popup__summary {
  font-size: 0.82rem;
  color: var(--text-secondary);
  line-height: 1.65;
}

.map-popup__footer {
  padding: var(--sp-4) var(--sp-5);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-3);
}

.map-popup__count {
  font-size: 0.65rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.map-popup__link {
  text-decoration: none;
}

/* ── Map status bar ─────────────────────────────────────────────────────────── */

.map-status-bar {
  position: fixed;
  bottom: var(--sp-4);
  left: calc(var(--sidebar-w) + var(--sp-4));
  z-index: 500;
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-2) var(--sp-4);
  background: rgba(8,13,18,0.85);
  backdrop-filter: blur(6px);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
  pointer-events: none;
}

.map-status-bar__sep { color: var(--text-ghost); }

/* ── Phase 15.5: Map Source Filter Bar ──────────────────────────────────────
   Floating pill row above the status bar — toggles signal layer by source. ─ */

.map-source-filter-bar {
  position:        fixed;
  bottom:          calc(var(--sp-4) + 38px);   /* sits just above status bar */
  left:            calc(var(--sidebar-w) + var(--sp-4));
  z-index:         500;
  display:         none;                        /* shown by JS when signals load */
  align-items:     center;
  gap:             var(--sp-2);
  padding:         var(--sp-2) var(--sp-3);
  background:      rgba(8, 13, 18, 0.88);
  backdrop-filter: blur(6px);
  border:          1px solid var(--border-dim);
  border-radius:   var(--r-sm);
}

.map-source-filter-bar__label {
  font-size:      0.55rem;
  letter-spacing: 0.12em;
  color:          var(--text-ghost);
  text-transform: uppercase;
  margin-right:   var(--sp-1);
}

.map-source-pill {
  padding:        2px 8px;
  border-radius:  3px;
  border:         1px solid rgba(255,255,255,0.10);
  background:     transparent;
  color:          var(--text-dim);
  font-size:      0.62rem;
  font-family:    var(--font-mono);
  letter-spacing: 0.06em;
  cursor:         pointer;
  transition:     all var(--t-fast);
}
.map-source-pill:hover {
  border-color: rgba(255,255,255,0.22);
  color:        var(--text-secondary);
}
.map-source-pill--active {
  color:        var(--text-primary);
  border-color: rgba(255,255,255,0.28);
  background:   rgba(255,255,255,0.06);
}
.map-source-pill--gdelt.map-source-pill--active {
  color:        #818cf8;
  background:   rgba(99, 102, 241, 0.15);
  border-color: rgba(99, 102, 241, 0.45);
}
.map-source-pill--gdacs.map-source-pill--active {
  color:        #34d399;
  background:   rgba(16, 185, 129, 0.12);
  border-color: rgba(16, 185, 129, 0.40);
}
.map-source-pill--rss.map-source-pill--active {
  color:        var(--accent);
  background:   rgba(200, 148, 58, 0.12);
  border-color: rgba(200, 148, 58, 0.40);
}
.map-source-pill--interpol.map-source-pill--active {
  color:        #fbbf24;
  background:   rgba(245, 158, 11, 0.12);
  border-color: rgba(245, 158, 11, 0.40);
}

/* ── Leaflet overrides — dark theme ─────────────────────────────────────────── */

.leaflet-container {
  background: var(--bg-void);
  font-family: var(--font-mono);
}

.leaflet-control-attribution {
  background: rgba(8,13,18,0.75) !important;
  color: var(--text-dim) !important;
  font-family: var(--font-mono);
  font-size: 0.6rem !important;
  border-top: 1px solid var(--border-dim) !important;
}

.leaflet-control-attribution a { color: var(--text-secondary) !important; }

.leaflet-control-zoom a {
  background: var(--bg-surface) !important;
  color: var(--text-secondary) !important;
  border-color: var(--border-mid) !important;
  font-size: 1rem !important;
}

.leaflet-control-zoom a:hover {
  background: var(--bg-elevated) !important;
  color: var(--accent) !important;
}

/* Custom marker — no background bleed */
.forge-marker,
.forge-cluster {
  background: none !important;
  border: none !important;
}

/* Cluster pill override */
.marker-cluster-small,
.marker-cluster-medium,
.marker-cluster-large {
  background: none !important;
}

.marker-cluster-small div,
.marker-cluster-medium div,
.marker-cluster-large div {
  background: none !important;
  color: var(--accent) !important;
}

/* ── Map responsive ─────────────────────────────────────────────────────────── */

@media (max-width: 700px) {
  #forge-map {
    left: 0;
  }

  .map-header {
    left: 0;
  }

  .map-status-bar {
    left: var(--sp-4);
  }

  .map-info-panel {
    width: 100%;
  }
}

/* ============================================================================
   PHASE 6 — Intelligence Graph
   D3 force simulation canvas + control bar + side panel + legend
   ============================================================================ */

/* ── Graph canvas wrap ──────────────────────────────────────────────────────── */

.graph-canvas-wrap {
  position: fixed;
  top:    calc(var(--topbar-h) + 52px);   /* below graph-bar */
  left:   var(--sidebar-w);
  right:  0;
  bottom: 0;
  background: var(--bg-void);
  background-image:
    radial-gradient(circle at 20% 30%, rgba(200,148,58,0.025) 0%, transparent 55%),
    radial-gradient(circle at 80% 70%, rgba(42,64,100,0.04)   0%, transparent 55%);
  overflow: hidden;
}

#js-graph-svg {
  width:  100%;
  height: 100%;
  display: block;
}

/* ── Graph control bar ──────────────────────────────────────────────────────── */

.graph-bar {
  position: fixed;
  top:   var(--topbar-h);
  left:  var(--sidebar-w);
  right: 0;
  z-index: 500;
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: 0 var(--sp-5);
  height: 52px;
  background: rgba(8,13,18,0.94);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border-dim);
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-width: none;
  flex-wrap: nowrap;
}

.graph-bar::-webkit-scrollbar { display: none; }

.graph-bar__left {
  flex-shrink: 0;
  margin-right: var(--sp-2);
}

.graph-bar__section {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-shrink: 0;
}

.graph-bar__section--slider {
  gap: var(--sp-3);
}

.graph-bar__label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  white-space: nowrap;
  flex-shrink: 0;
}

.graph-bar__divider {
  width: 1px;
  height: 24px;
  background: var(--border-dim);
  flex-shrink: 0;
}

.graph-bar__stats {
  display: flex;
  align-items: center;
  gap: var(--sp-4);
  flex-shrink: 0;
  margin-left: auto;
}

/* ── Graph toggle buttons ───────────────────────────────────────────────────── */

.graph-toggle {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-1);
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.04em;
  padding: 3px var(--sp-3);
  border: 1px solid var(--border-dim);
  border-radius: 2px;
  color: var(--text-dim);
  background: transparent;
  cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
  white-space: nowrap;
  flex-shrink: 0;
}

.graph-toggle:hover {
  border-color: var(--border-mid);
  color: var(--text-secondary);
}

.graph-toggle--active {
  color: var(--text-primary);
  border-color: var(--border-mid);
  background: var(--bg-elevated);
}

.graph-toggle__dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* Actor type dot colours */
.graph-toggle__dot--person      { background: #8ab4d0; }
.graph-toggle__dot--institution { background: #c8943a; }
.graph-toggle__dot--media       { background: #7a9aba; }
.graph-toggle__dot--movement    { background: #8aaa6a; }
.graph-toggle__dot--government  { background: #6a9de0; }
.graph-toggle__dot--paramilitary{ background: #cc5555; }

/* Event category dot colours */
.graph-toggle__dot--cat-election     { background: #9a7acc; }
.graph-toggle__dot--cat-security     { background: #cc5555; }
.graph-toggle__dot--cat-civil-unrest { background: #cc8844; }
.graph-toggle__dot--cat-legislative  { background: #5588cc; }
.graph-toggle__dot--cat-economic     { background: #55aa77; }
.graph-toggle__dot--cat-diplomatic   { background: #aa77cc; }
.graph-toggle__dot--cat-military     { background: #aa3333; }
.graph-toggle__dot--cat-social       { background: #5a9a88; }
.graph-toggle__dot--cat-other        { background: #5a6a7a; }

/* ── Weight slider ──────────────────────────────────────────────────────────── */

.graph-slider {
  -webkit-appearance: none;
  width: 80px;
  height: 3px;
  background: var(--bg-overlay);
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}

.graph-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg-base);
  cursor: pointer;
  transition: background var(--t-fast);
}

.graph-slider::-webkit-slider-thumb:hover { background: var(--accent-bright); }
.graph-slider::-moz-range-thumb {
  width: 12px; height: 12px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg-base);
  cursor: pointer;
}

/* ── Graph stat pills ───────────────────────────────────────────────────────── */

.graph-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1px;
}

.graph-stat__val {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--accent);
  line-height: 1;
  min-width: 2ch;
  text-align: center;
}

.graph-stat__label {
  font-size: 0.55rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ── Graph icon button ──────────────────────────────────────────────────────── */

.graph-icon-btn {
  width: 28px;
  height: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.9rem;
  color: var(--text-dim);
  background: transparent;
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  cursor: pointer;
  transition: color var(--t-fast), border-color var(--t-fast), background var(--t-fast);
  flex-shrink: 0;
}

.graph-icon-btn:hover {
  color: var(--accent);
  border-color: var(--accent-muted);
  background: var(--accent-glow);
}

/* ── Loading overlay ────────────────────────────────────────────────────────── */

.graph-loading {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--sp-4);
  background: var(--bg-void);
  z-index: 10;
}

.graph-loading__spinner {
  width: 32px;
  height: 32px;
  border: 2px solid var(--border-dim);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.graph-loading__label {
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

/* ── Empty state ────────────────────────────────────────────────────────────── */

.graph-empty {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

/* ── D3 node / link classes ─────────────────────────────────────────────────── */

.graph-node {
  transition: opacity 200ms;
}

.graph-node--faded { opacity: 0.08; }

.graph-node--active circle,
.graph-node--active polygon,
.graph-node--active rect {
  filter: url(#glow);
}

.graph-link {
  transition: opacity 200ms, stroke 150ms;
}

.graph-link--faded  { opacity: 0.04 !important; }
.graph-link--active { opacity: 1   !important; }

.graph-label {
  font-family: 'IBM Plex Mono', monospace;
  user-select: none;
  pointer-events: none;
  text-shadow:
    0 1px 4px #05080b,
    0 0   8px #05080b;
}

/* ── Side panel (same pattern as map panel) ─────────────────────────────────── */

.graph-panel {
  position: fixed;
  right:  0;
  top:    calc(var(--topbar-h) + 52px);
  bottom: 0;
  width:  320px;
  background: var(--bg-surface);
  border-left: 1px solid var(--border-dim);
  z-index: 600;
  transform: translateX(100%);
  transition: transform 260ms cubic-bezier(0.4, 0, 0.2, 1);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.graph-panel--open { transform: translateX(0); }

.graph-panel__close {
  position: absolute;
  top: var(--sp-3);
  right: var(--sp-3);
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-dim);
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  cursor: pointer;
  transition: color var(--t-fast), border-color var(--t-fast);
  z-index: 1;
}

.graph-panel__close:hover {
  color: var(--text-primary);
  border-color: var(--border-mid);
}

.graph-panel__content { flex: 1; }

/* ── Panel inner layout (gpanel__*) ─────────────────────────────────────────── */

.gpanel__header {
  padding: var(--sp-5) var(--sp-5) var(--sp-4);
  border-left: 3px solid var(--accent);
  border-bottom: 1px solid var(--border-dim);
  margin-left: -1px;
}

.gpanel__kind {
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
}

.gpanel__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: var(--sp-2);
}

.gpanel__date,
.gpanel__location {
  font-size: 0.68rem;
  color: var(--text-dim);
  margin-top: 2px;
  letter-spacing: 0.04em;
}

.gpanel__body {
  padding: var(--sp-4) var(--sp-5);
  border-bottom: 1px solid var(--border-dim);
}

.gpanel__desc {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.65;
}

.gpanel__section {
  padding: var(--sp-4) var(--sp-5);
  border-bottom: 1px solid var(--border-dim);
}

.gpanel__section-label {
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-3);
}

.gpanel__stat-row {
  display: flex;
  gap: var(--sp-6);
}

.gpanel__stat {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.gpanel__stat-val {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.3rem;
  color: var(--accent);
  line-height: 1;
}

.gpanel__stat-label {
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.gpanel__footer {
  padding: var(--sp-4) var(--sp-5);
  margin-top: auto;
}

.gpanel__cta {
  text-decoration: none;
  width: 100%;
  justify-content: center;
}

/* ── Graph legend ───────────────────────────────────────────────────────────── */

.graph-legend {
  position: fixed;
  bottom: var(--sp-5);
  left: calc(var(--sidebar-w) + var(--sp-5));
  z-index: 400;
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  padding: var(--sp-3) var(--sp-4);
  background: rgba(8,13,18,0.85);
  backdrop-filter: blur(6px);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  pointer-events: none;
}

.graph-legend__row {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  font-family: var(--font-mono);
  font-size: 0.62rem;
  color: var(--text-dim);
}

.graph-legend__row--weight {
  border-top: 1px solid var(--border-dim);
  padding-top: var(--sp-2);
  margin-top: var(--sp-1);
}

/* ── Responsive ─────────────────────────────────────────────────────────────── */

@media (max-width: 900px) {
  .graph-canvas-wrap { left: 0; }
  .graph-bar         { left: 0; }
  .graph-legend      { left: var(--sp-4); }
  .graph-panel       { width: 100%; max-width: 360px; }
}

/* ============================================================================
   PHASE 7 — Dossier Engine: Print-ready intelligence briefs
   ============================================================================ */

/* ── Page-header actions row ────────────────────────────────────────────────── */

.page-header__actions {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  margin-top: var(--sp-3);
  flex-wrap: wrap;
}

/* Small button modifier */
.btn--sm {
  font-size: 0.68rem;
  padding: var(--sp-1) var(--sp-3);
}

/* Dossier / print button */
.btn--dossier {
  background: transparent;
  border-color: var(--accent-muted);
  color: var(--accent);
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  padding: var(--sp-2) var(--sp-4);
  border-radius: var(--r-sm);
  border: 1px solid;
  cursor: pointer;
  text-decoration: none;
  transition: background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
}

.btn--dossier:hover {
  background: var(--accent-glow);
  border-color: var(--accent);
  color: var(--accent-bright);
}

/* btn--secondary (referenced in admin but not yet defined) */
.btn--secondary {
  background: transparent;
  border-color: var(--border-mid);
  color: var(--text-secondary);
}

.btn--secondary:hover {
  background: var(--bg-overlay);
  border-color: var(--border-bright);
  color: var(--text-primary);
}

.btn--full { width: 100%; justify-content: center; }

/* ── Dossier page layout ────────────────────────────────────────────────────── */

.dossier-page {
  background: var(--bg-base);
  min-height: 100vh;
}

/* ── Dossier header ─────────────────────────────────────────────────────────── */

.dossier-header {
  margin-bottom: 3rem;
  padding-bottom: 1.5rem;
  border-bottom: 2px solid var(--border-mid);
}

.dossier-header__strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border-dim);
  flex-wrap: wrap;
}

.dossier-header__classification {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.dossier-header__actions {
  display: flex;
  gap: var(--sp-3);
  align-items: center;
}

.dossier-btn {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: var(--sp-2) var(--sp-4);
  border-radius: var(--r-sm);
  border: 1px solid;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  transition: background var(--t-fast), color var(--t-fast);
}

.dossier-btn--ghost {
  background: transparent;
  border-color: var(--border-mid);
  color: var(--text-secondary);
}

.dossier-btn--ghost:hover {
  background: var(--bg-elevated);
  color: var(--text-primary);
}

.dossier-btn--primary {
  background: var(--accent-muted);
  border-color: var(--accent-muted);
  color: var(--text-primary);
}

.dossier-btn--primary:hover {
  background: var(--accent);
  color: var(--bg-void);
}

.dossier-header__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 0.5rem;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-2);
}

.dossier-header__title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 2rem;
  color: var(--text-primary);
  line-height: 1.15;
  margin-bottom: 0.4rem;
  letter-spacing: -0.01em;
}

.dossier-header__sub {
  font-size: 0.8rem;
  color: var(--text-secondary);
  margin-bottom: 1.25rem;
  letter-spacing: 0.03em;
}

.dossier-header__meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 1.5rem 3rem;
  padding-top: 1rem;
  border-top: 1px solid var(--border-dim);
}

.dossier-header__meta-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.dossier-header__meta-label {
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.dossier-header__meta-value {
  font-size: 0.78rem;
  color: var(--text-secondary);
  letter-spacing: 0.02em;
}

/* ── Dossier section ────────────────────────────────────────────────────────── */

.dossier-section {
  margin-bottom: 3rem;
}

.dossier-section__header {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid var(--border-dim);
  margin-bottom: 1.25rem;
}

.dossier-section__num {
  font-size: 0.6rem;
  letter-spacing: 0.14em;
  color: var(--accent-muted);
}

.dossier-section__title {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

/* ── Dossier prose ──────────────────────────────────────────────────────────── */

.dossier-prose {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.8;
  max-width: 720px;
}

.dossier-prose--empty {
  font-style: italic;
  color: var(--text-dim);
}

.dossier-source-summary {
  margin-top: 1.25rem;
  padding: 0.75rem 1rem;
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
}

/* ── Dossier table ──────────────────────────────────────────────────────────── */

.dossier-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
  margin-bottom: 1rem;
}

.dossier-table th {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding: 0.5rem 0.75rem;
  text-align: left;
  border-bottom: 1px solid var(--border-dim);
  white-space: nowrap;
}

.dossier-table td {
  padding: 0.6rem 0.75rem;
  border-bottom: 1px solid var(--border-dim);
  color: var(--text-secondary);
  vertical-align: top;
  line-height: 1.4;
}

.dossier-table tr:last-child td { border-bottom: none; }

.dossier-table tr:hover td {
  background: var(--bg-elevated);
}

.dossier-table--evidence td { padding: 0.5rem 0.75rem; }

.dossier-evidence-group-header {
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  color: var(--accent);
  padding: 0.6rem 0.75rem 0.3rem;
  border-bottom: 1px solid var(--border-dim);
  margin-top: 1rem;
}

.dossier-evidence-group-header a { color: inherit; }
.dossier-evidence-group-header a:hover { color: var(--accent-bright); }

.dossier-link {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--accent);
  white-space: nowrap;
}

.dossier-link:hover { color: var(--accent-bright); }

/* ── Dossier timeline (actor events section) ────────────────────────────────── */

.dossier-timeline {
  display: flex;
  flex-direction: column;
}

.dossier-timeline__item {
  display: flex;
  gap: 1rem;
}

.dossier-timeline__spine {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  padding-top: 3px;
}

.dossier-timeline__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  border: 2px solid var(--accent-muted);
  background: var(--bg-base);
  flex-shrink: 0;
}

/* Category dot colours */
.dossier-timeline__dot--election    { border-color: #6a4aaa; }
.dossier-timeline__dot--security    { border-color: #c04040; }
.dossier-timeline__dot--civil-unrest{ border-color: #c07830; }
.dossier-timeline__dot--legislative { border-color: #3a70c0; }
.dossier-timeline__dot--other       { border-color: #4a5a6a; }

.dossier-timeline__line {
  width: 1px;
  flex: 1;
  min-height: 20px;
  background: var(--border-dim);
  margin: 4px 0;
}

.dossier-timeline__body {
  padding-bottom: 1.25rem;
  flex: 1;
  min-width: 0;
}

.dossier-timeline__header {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-2);
  margin-bottom: 0.3rem;
}

.dossier-timeline__date {
  font-size: 0.68rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

.dossier-timeline__title {
  font-weight: 500;
  font-size: 0.9rem;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: 0.25rem;
}

.dossier-timeline__title a { color: inherit; }
.dossier-timeline__title a:hover { color: var(--accent); }

.dossier-timeline__location {
  font-size: 0.65rem;
  color: var(--text-dim);
  margin-bottom: 0.3rem;
}

.dossier-timeline__summary {
  font-size: 0.8rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 0.3rem;
}

.dossier-timeline__count {
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
}

/* ── Dossier footer ─────────────────────────────────────────────────────────── */

.dossier-footer {
  margin-top: 4rem;
  padding-top: 1rem;
}

.dossier-footer__rule {
  font-size: 0.55rem;
  color: var(--text-ghost);
  letter-spacing: 0;
  overflow: hidden;
  margin-bottom: 0.5rem;
}

.dossier-footer__body {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.5rem;
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}

.dossier-footer__disclaimer {
  font-size: 0.6rem;
  color: var(--text-ghost);
  letter-spacing: 0.04em;
}

/* ============================================================================
   PRINT MEDIA RULES
   Activated by Ctrl+P or window.print() on any dossier page.
   Ink-saving: white backgrounds, dark text, no decorative colours.
   Page-break control keeps sections coherent across physical pages.
   ============================================================================ */

@media print {

  /* ── Reset background / colour ──────────────────────────────────────────── */

  *,
  *::before,
  *::after {
    background: white !important;
    background-image: none !important;
    box-shadow: none !important;
    text-shadow: none !important;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  body {
    color: #1a1a1a;
    font-size: 11pt;
    line-height: 1.5;
  }

  /* ── Hide interactive / screen-only chrome ──────────────────────────────── */

  .no-print,
  .dossier-header__actions,
  nav.breadcrumb { display: none !important; }

  /* ── Links — show URL hint in parentheses ───────────────────────────────── */

  a { color: #1a1a1a; text-decoration: underline; }

  /* Don't expand every link — only main navigational CTAs */
  .dossier-link::after,
  .dossier-btn::after { content: none; }

  /* ── Dossier body max-width for print ───────────────────────────────────── */

  .dossier-body {
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* ── Header: dark text, remove glow / bg ───────────────────────────────── */

  .dossier-header {
    border-bottom-color: #888 !important;
    margin-bottom: 1.5rem;
  }

  .dossier-header__classification {
    color: #555 !important;
    border-bottom-color: #ccc !important;
  }

  .dossier-header__title {
    color: #000 !important;
    font-size: 22pt;
  }

  .dossier-header__sub,
  .dossier-header__meta-value { color: #333 !important; }

  .dossier-header__meta-label { color: #666 !important; }

  .dossier-header__meta-row {
    border-top-color: #ccc !important;
    padding-top: 0.5rem;
  }

  /* ── Sections ───────────────────────────────────────────────────────────── */

  .dossier-section { margin-bottom: 2rem; }

  .dossier-section__header {
    border-bottom-color: #aaa !important;
  }

  .dossier-section__num  { color: #888 !important; }
  .dossier-section__title{ color: #333 !important; }

  /* ── Badges — print as outlined mono text ───────────────────────────────── */

  .source-badge,
  .category-badge,
  .actor-type-badge,
  .role-badge,
  .type-badge {
    border: 1px solid #888 !important;
    color: #333 !important;
    font-family: 'Courier New', monospace !important;
    font-size: 8pt !important;
    padding: 1px 4px !important;
  }

  /* ── Tables ─────────────────────────────────────────────────────────────── */

  .dossier-table {
    border: 1px solid #ccc !important;
    font-size: 9pt;
  }

  .dossier-table th {
    color: #333 !important;
    border-bottom-color: #888 !important;
    background: #f0f0f0 !important;
  }

  .dossier-table td {
    color: #1a1a1a !important;
    border-bottom-color: #ddd !important;
  }

  .dossier-table tr:hover td { background: white !important; }

  .dossier-evidence-group-header {
    color: #333 !important;
    border-bottom-color: #bbb !important;
    background: #f8f8f8 !important;
    font-weight: bold;
  }

  /* ── Timeline ───────────────────────────────────────────────────────────── */

  .dossier-timeline__dot {
    border-color: #888 !important;
    background: white !important;
  }

  .dossier-timeline__line { background: #ccc !important; }

  .dossier-timeline__title { color: #000 !important; }
  .dossier-timeline__date  { color: #555 !important; }
  .dossier-timeline__summary{ color: #333 !important; }

  /* ── Prose ──────────────────────────────────────────────────────────────── */

  .dossier-prose { color: #1a1a1a !important; }
  .dossier-source-summary { border-color: #ccc !important; }

  /* ── Footer ─────────────────────────────────────────────────────────────── */

  .dossier-footer__rule        { color: #bbb !important; }
  .dossier-footer__body        { color: #666 !important; border-top: 1px solid #ccc; padding-top: 0.3rem; }
  .dossier-footer__disclaimer  { color: #999 !important; }

  /* ── Page-break control ─────────────────────────────────────────────────── */

  /* Explicit break points */
  .page-break-before { page-break-before: always; break-before: page; }
  .page-break-after  { page-break-after:  always; break-after:  page; }
  .no-page-break     { page-break-inside: avoid;  break-inside:  avoid; }

  /* Keep table header with first data row */
  .dossier-table thead { display: table-header-group; }
  .dossier-table tr    { page-break-inside: avoid; break-inside: avoid; }

  /* Each timeline item stays together */
  .dossier-timeline__item { page-break-inside: avoid; break-inside: avoid; }

  /* Section headers never orphaned at page bottom */
  .dossier-section__header {
    page-break-after: avoid;
    break-after: avoid;
  }

  /* ── Page margins / size ────────────────────────────────────────────────── */

  @page {
    margin: 18mm 20mm 18mm 20mm;
    size: A4 portrait;
  }

  @page :first {
    margin-top: 14mm;
  }
}

/* ============================================================================
   PHASE 8 — Case Workspaces + Edit/Delete System
   ============================================================================ */

/* ── btn--danger ─────────────────────────────────────────────────────────── */

.btn--danger {
  background: transparent;
  border: 1px solid rgba(170,50,50,0.5);
  color: #cc5555;
}

.btn--danger:hover {
  background: rgba(170,50,50,0.12);
  border-color: #cc5555;
  color: #e06060;
}

/* ── Case status badges ──────────────────────────────────────────────────── */

.case-status-badge {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 2px var(--sp-2);
  border-radius: 2px;
  border: 1px solid;
}

.case-status-badge--active   { color: #4aaa66; border-color: rgba(74,170,102,0.4); background: rgba(74,170,102,0.08); }
.case-status-badge--closed   { color: #c8943a; border-color: rgba(200,148,58,0.4); background: rgba(200,148,58,0.08); }
.case-status-badge--archived { color: var(--text-dim); border-color: var(--border-dim); }

/* ── Cases index ─────────────────────────────────────────────────────────── */

.case-create-panel {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-4) var(--sp-5);
  margin-bottom: var(--sp-8);
}

.case-create-panel__header {
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-3);
}

.case-create-form__row {
  display: flex;
  gap: var(--sp-3);
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: var(--sp-3);
}

.case-create-form__input {
  flex: 1;
  min-width: 200px;
}

.case-create-form__select {
  width: auto;
  flex-shrink: 0;
}

.case-create-form__textarea {
  width: 100%;
  min-height: 52px;
  resize: vertical;
}

.case-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: var(--sp-4);
}

.case-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-5);
  text-decoration: none;
  transition: background var(--t-fast), border-color var(--t-fast), transform var(--t-fast);
}

.case-card:hover {
  background: var(--bg-elevated);
  border-color: var(--border-mid);
  transform: translateY(-1px);
}

.case-card__top { margin-bottom: var(--sp-4); }

.case-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--sp-3);
}

.case-card__id {
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
}

.case-card__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--text-primary);
  margin-bottom: var(--sp-2);
  line-height: 1.3;
}

.case-card__desc {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.case-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: var(--sp-3);
  border-top: 1px solid var(--border-dim);
}

.case-card__counts {
  display: flex;
  gap: var(--sp-3);
}

.case-card__count {
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

.case-card__date {
  font-size: 0.62rem;
  color: var(--text-dim);
}

/* ── Board layout (case_detail.html) ─────────────────────────────────────── */

.board-layout {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-5);
  align-items: start;
}

@media (max-width: 1100px) {
  .board-layout { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 700px) {
  .board-layout { grid-template-columns: 1fr; }
}

.board-column {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  min-height: 200px;
}

.board-column__header {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
  position: sticky;
  top: var(--topbar-h);
  background: var(--bg-surface);
  z-index: 2;
  border-radius: var(--r-sm) var(--r-sm) 0 0;
}

.board-column__icon {
  font-size: 0.9rem;
  color: var(--accent);
}

.board-column__title {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-secondary);
  flex: 1;
}

.board-column__count {
  font-size: 0.62rem;
  color: var(--text-dim);
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  padding: 1px 6px;
  border-radius: 10px;
}

.board-column__items {
  padding: var(--sp-3);
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.board-column__empty {
  padding: var(--sp-5) var(--sp-4);
  font-size: 0.7rem;
  color: var(--text-ghost);
  text-align: center;
  letter-spacing: 0.06em;
}

/* ── Board cards ────────────────────────────────────────────────────────── */

.board-card {
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-3) var(--sp-4);
  transition: border-color var(--t-fast);
}

.board-card:hover { border-color: var(--border-mid); }

.board-card--actor  { border-left: 2px solid #6a9de0; }
.board-card--event  { border-left: 2px solid var(--accent-muted); }
.board-card--artifact { border-left: 2px solid #5a7a9a; }

.board-card__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--sp-2);
}

.board-card__meta {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
}

.board-card__date {
  font-size: 0.6rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

.board-card__unpin {
  font-size: 0.75rem;
  color: var(--text-dim);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0 var(--sp-1);
  line-height: 1;
  flex-shrink: 0;
  transition: color var(--t-fast);
}

.board-card__unpin:hover { color: #cc5555; }

.board-card__title {
  display: block;
  font-weight: 500;
  font-size: 0.85rem;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: var(--sp-1);
  text-decoration: none;
}

.board-card__title:hover { color: var(--accent); }

.board-card__location {
  font-size: 0.65rem;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
  letter-spacing: 0.03em;
}

.board-card__desc {
  font-size: 0.77rem;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: var(--sp-2);
}

.board-card__stats {
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
  margin-bottom: var(--sp-2);
}

.board-card__note {
  background: var(--bg-overlay);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-2) var(--sp-3);
  margin-bottom: var(--sp-2);
  font-size: 0.75rem;
  color: var(--text-secondary);
  line-height: 1.5;
}

.board-card__note-label {
  font-size: 0.58rem;
  color: var(--text-dim);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-right: var(--sp-2);
}

.board-card__note-btn {
  font-size: 0.62rem;
  letter-spacing: 0.06em;
  color: var(--text-dim);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  transition: color var(--t-fast);
}

.board-card__note-btn:hover { color: var(--accent); }

/* ── Pin Widget ──────────────────────────────────────────────────────────── */

.pin-widget {
  position: relative;
  display: inline-flex;
  flex-shrink: 0;
}

.pin-widget__btn {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: var(--sp-2) var(--sp-4);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  background: transparent;
  color: var(--text-dim);
  cursor: pointer;
  transition: all var(--t-fast);
  white-space: nowrap;
}

.pin-widget__btn:hover,
.pin-widget__btn--active {
  border-color: var(--accent-muted);
  color: var(--accent);
  background: var(--accent-glow);
}

.pin-widget__icon { font-size: 0.85rem; }

.pin-widget__dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  z-index: 900;
  width: 280px;
  background: var(--bg-elevated);
  border: 1px solid var(--border-mid);
  border-radius: var(--r-sm);
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  overflow: hidden;
}

.pin-widget__dropdown--open { display: block; }

.pin-widget__dropdown-header {
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
  background: var(--bg-surface);
}

.pin-widget__cases {
  max-height: 220px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border-mid) transparent;
}

.pin-widget__loading {
  font-size: 0.7rem;
  color: var(--text-dim);
  padding: var(--sp-4);
  text-align: center;
}

.pin-widget__case-row {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  width: 100%;
  padding: var(--sp-3) var(--sp-4);
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--border-dim);
  cursor: pointer;
  text-align: left;
  transition: background var(--t-fast);
  color: var(--text-secondary);
  font-size: 0.82rem;
}

.pin-widget__case-row:hover { background: var(--bg-overlay); }
.pin-widget__case-row--pinned { color: var(--accent); }

.pin-widget__case-icon { font-size: 0.8rem; flex-shrink: 0; }
.pin-widget__case-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.pin-widget__dropdown-footer {
  padding: var(--sp-2) var(--sp-4);
  background: var(--bg-surface);
  border-top: 1px solid var(--border-dim);
}

.pin-widget__manage {
  font-size: 0.62rem;
  letter-spacing: 0.06em;
  color: var(--text-dim);
  text-decoration: none;
  transition: color var(--t-fast);
}

.pin-widget__manage:hover { color: var(--accent); }

/* ── Modal system ────────────────────────────────────────────────────────── */

.modal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 2000;
}

.modal--open { display: flex; align-items: center; justify-content: center; }

.modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(4px);
}

.modal__box {
  position: relative;
  z-index: 1;
  background: var(--bg-elevated);
  border: 1px solid var(--border-mid);
  border-radius: var(--r-sm);
  width: 90%;
  max-width: 520px;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  animation: modalSlideIn 0.2s ease;
}

.modal__box--sm { max-width: 380px; }

@keyframes modalSlideIn {
  from { opacity: 0; transform: translateY(-12px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0)     scale(1);    }
}

.modal__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-4) var(--sp-5);
  border-bottom: 1px solid var(--border-dim);
}

.modal__title {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

.modal__close {
  font-size: 0.75rem;
  color: var(--text-dim);
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px var(--sp-2);
  transition: color var(--t-fast);
}

.modal__close:hover { color: var(--text-primary); }

.modal__body {
  padding: var(--sp-5);
}

.modal__footer {
  display: flex;
  justify-content: flex-end;
  gap: var(--sp-3);
  padding: var(--sp-4) var(--sp-5);
  border-top: 1px solid var(--border-dim);
  background: var(--bg-surface);
}

/* ── Edit form wrapper ───────────────────────────────────────────────────── */

.edit-form-wrap {
  max-width: 720px;
}

.edit-form-actions {
  display: flex;
  gap: var(--sp-3);
  margin-top: var(--sp-5);
  padding-top: var(--sp-5);
  border-top: 1px solid var(--border-dim);
  align-items: center;
}

/* ============================================================================
   PHASE 9 — Inference Engine: Discovery Sidebar, Heat Score, Analytics Bar
   ============================================================================ */

/* ── Workspace layout: board + sidebar ──────────────────────────────────── */

.workspace-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: var(--sp-5);
  align-items: start;
}

@media (max-width: 1280px) {
  .workspace-layout {
    grid-template-columns: 1fr 280px;
  }
}

@media (max-width: 1024px) {
  .workspace-layout {
    grid-template-columns: 1fr;
  }
  .discovery-sidebar {
    order: -1;           /* sidebar rises above board on narrow screens */
  }
}

.workspace-layout__main {
  display: flex;
  flex-direction: column;
  gap: var(--sp-5);
  min-width: 0;
}

/* ── Analytics bar ───────────────────────────────────────────────────────── */

.analytics-bar {
  display: flex;
  align-items: center;
  gap: var(--sp-5);
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-4) var(--sp-5);
  flex-wrap: wrap;
}

.analytics-bar__divider {
  width: 1px;
  height: 52px;
  background: var(--border-dim);
  flex-shrink: 0;
}

@media (max-width: 860px) {
  .analytics-bar__divider { display: none; }
}

/* ── Heat gauge ──────────────────────────────────────────────────────────── */

.heat-gauge {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  flex-shrink: 0;
}

.heat-gauge__ring-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  flex-shrink: 0;
}

.heat-gauge__ring {
  position: absolute;
  inset: 0;
}

.heat-gauge__track {
  stroke: var(--bg-elevated);
}

.heat-gauge__fill {
  stroke: #4aaa66;           /* overridden by JS */
  stroke-linecap: round;
  transition: stroke-dasharray 0.9s cubic-bezier(0.4, 0, 0.2, 1),
              stroke 0.4s ease;
}

.heat-gauge__value {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-primary);
  z-index: 1;
  line-height: 1;
  letter-spacing: -0.02em;
}

.heat-gauge__labels {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.heat-gauge__title {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.heat-gauge__label {
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-weight: 600;
  color: #4aaa66;            /* overridden by JS */
  transition: color 0.4s ease;
}

/* ── Sub-metric bars ─────────────────────────────────────────────────────── */

.analytics-metrics {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  flex: 1;
  min-width: 180px;
}

.analytics-metric__header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 4px;
}

.analytics-metric__name {
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.analytics-metric__val {
  font-size: 0.65rem;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
  min-width: 28px;
  text-align: right;
}

.analytics-metric__bar-track {
  height: 4px;
  background: var(--bg-elevated);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 3px;
}

.analytics-metric__bar {
  height: 100%;
  border-radius: 2px;
  width: 0%;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.analytics-metric__bar--density      { background: #6a9de0; }
.analytics-metric__bar--volatility   { background: #c8943a; }
.analytics-metric__bar--connectivity { background: #4aaa66; }

.analytics-metric__hint {
  font-size: 0.58rem;
  color: var(--text-ghost);
  font-family: var(--font-mono);
  letter-spacing: 0.04em;
}

/* ── Analytics pin counts ────────────────────────────────────────────────── */

.analytics-pins {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  flex-shrink: 0;
}

.analytics-pin-stat {
  display: flex;
  align-items: baseline;
  gap: var(--sp-2);
}

.analytics-pin-stat__val {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
  min-width: 24px;
  text-align: right;
}

.analytics-pin-stat__label {
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
}

/* ── Discovery Sidebar ───────────────────────────────────────────────────── */

.discovery-sidebar {
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  display: flex;
  flex-direction: column;
  gap: 0;
  position: sticky;
  top: calc(var(--topbar-h) + var(--sp-4));
  max-height: calc(100vh - var(--topbar-h) - var(--sp-8));
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border-mid) transparent;
}

.discovery-sidebar__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
  background: var(--bg-surface);
  position: sticky;
  top: 0;
  z-index: 2;
}

.discovery-sidebar__title {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: var(--sp-2);
}

.discovery-sidebar__refresh {
  font-size: 0.9rem;
  color: var(--text-dim);
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px var(--sp-2);
  line-height: 1;
  border-radius: var(--r-sm);
  transition: color var(--t-fast), transform 0.3s ease;
}

.discovery-sidebar__refresh:hover {
  color: var(--accent);
  transform: rotate(180deg);
}

.discovery-sidebar__empty {
  padding: var(--sp-5) var(--sp-4);
  font-size: 0.7rem;
  color: var(--text-ghost);
  text-align: center;
  line-height: 1.6;
  letter-spacing: 0.04em;
}

/* ── Filter pills ────────────────────────────────────────────────────────── */

.discovery-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
  background: var(--bg-surface);
  position: sticky;
  top: 41px;         /* below header */
  z-index: 1;
}

.discovery-filter__pill {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 3px 8px;
  border: 1px solid var(--border-dim);
  border-radius: 10px;
  background: transparent;
  color: var(--text-dim);
  cursor: pointer;
  transition: all var(--t-fast);
  white-space: nowrap;
}

.discovery-filter__pill:hover {
  border-color: var(--border-mid);
  color: var(--text-secondary);
}

.discovery-filter__pill--active {
  border-color: var(--accent-muted);
  color: var(--accent);
  background: var(--accent-glow);
}

/* ── Loading spinner ─────────────────────────────────────────────────────── */

.discovery-loading {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  padding: var(--sp-5) var(--sp-4);
  font-size: 0.7rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
}

.discovery-loading__spinner {
  width: 14px;
  height: 14px;
  border: 2px solid var(--border-dim);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── Lead cards ──────────────────────────────────────────────────────────── */

.discovery-leads {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.lead-card {
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--border-dim);
  transition: background var(--t-fast);
  animation: leadFadeIn 0.3s ease both;
}

@keyframes leadFadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0);   }
}

.lead-card:hover {
  background: var(--bg-elevated);
}

.lead-card--event    { border-left: 2px solid var(--accent-muted); }
.lead-card--actor    { border-left: 2px solid #6a9de0; }
.lead-card--artifact { border-left: 2px solid #5a7a9a; }

.lead-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--sp-2);
}

.lead-card__icon {
  font-size: 0.8rem;
  color: var(--text-dim);
  flex-shrink: 0;
}

/* ── Confidence indicator ────────────────────────────────────────────────── */

.lead-confidence {
  display: flex;
  align-items: center;
  gap: 5px;
}

.lead-confidence__label {
  font-size: 0.55rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 600;
  min-width: 38px;
  text-align: right;
}

.lead-confidence__bar-track {
  width: 40px;
  height: 3px;
  background: var(--bg-elevated);
  border-radius: 2px;
  overflow: hidden;
}

.lead-confidence__bar {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s ease;
}

.lead-confidence__pct {
  font-size: 0.58rem;
  color: var(--text-dim);
  min-width: 28px;
  text-align: right;
}

/* Confidence colour variants */
.lead-confidence--high .lead-confidence__label  { color: #4aaa66; }
.lead-confidence--high .lead-confidence__bar    { background: #4aaa66; }
.lead-confidence--medium .lead-confidence__label { color: #c8943a; }
.lead-confidence--medium .lead-confidence__bar   { background: #c8943a; }
.lead-confidence--low .lead-confidence__label    { color: var(--text-dim); }
.lead-confidence--low .lead-confidence__bar      { background: var(--border-mid); }

/* ── Lead card body ──────────────────────────────────────────────────────── */

.lead-card__title {
  font-weight: 500;
  font-size: 0.82rem;
  color: var(--text-primary);
  line-height: 1.3;
  margin-bottom: var(--sp-2);
}

.lead-card__meta {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
  margin-bottom: var(--sp-2);
}

.lead-card__reason {
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.03em;
  line-height: 1.5;
  margin-bottom: var(--sp-3);
  /* truncate long reasons */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.lead-card__actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-2);
}

.lead-card__view {
  font-size: 0.62rem;
  color: var(--text-dim);
  text-decoration: none;
  letter-spacing: 0.06em;
  transition: color var(--t-fast);
}

.lead-card__view:hover {
  color: var(--accent);
}

.lead-card__pin {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 8px;
  border: 1px solid var(--accent-muted);
  border-radius: var(--r-sm);
  background: var(--accent-glow);
  color: var(--accent);
  cursor: pointer;
  transition: all var(--t-fast);
  white-space: nowrap;
}

.lead-card__pin:hover:not(:disabled) {
  background: var(--accent-muted);
  color: var(--bg-base);
}

.lead-card__pin:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}


/* ============================================================================
   PHASE 10 — Narrative Threader: mode toolbar, sequence badges, transition fields
   ============================================================================ */

/* ── Narrative toolbar ───────────────────────────────────────────────────── */

.narrative-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-4);
  flex-wrap: wrap;
  background: var(--bg-elevated);
  border: 1px solid var(--accent-muted);
  border-radius: var(--r-sm);
  padding: var(--sp-3) var(--sp-5);
  margin-bottom: var(--sp-5);
  box-shadow: 0 0 24px var(--accent-glow);
  animation: toolbarSlideDown 0.2s ease;
}

@keyframes toolbarSlideDown {
  from { opacity: 0; transform: translateY(-8px); }
  to   { opacity: 1; transform: translateY(0);    }
}

.narrative-toolbar__left {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  flex-wrap: wrap;
}

.narrative-toolbar__right {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-wrap: wrap;
}

.narrative-toolbar__icon { font-size: 1rem; }

.narrative-toolbar__label {
  font-size: 0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 600;
}

.narrative-toolbar__hint {
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
}

/* ── Board card narrative state ──────────────────────────────────────────── */

.board-card--narrative {
  border-color: var(--border-mid);
  cursor: grab;
}

.board-card--narrative:active { cursor: grabbing; }

/* SortableJS ghost / chosen classes */
.board-card--dragging {
  opacity: 0.4;
  background: var(--bg-elevated) !important;
}

.board-card--chosen {
  box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 0 2px var(--accent-muted);
  transform: scale(1.02);
  z-index: 100;
}

.board-card--drag {
  box-shadow: 0 8px 30px rgba(0,0,0,0.6), 0 0 0 2px var(--accent-muted);
}

/* ── Narrative controls: drag handle + sequence badge ─────────────────── */

.narrative-controls {
  display: none;                     /* shown by JS in narrative mode */
  align-items: center;
  gap: var(--sp-2);
  margin-bottom: var(--sp-2);
}

.narrative-drag-handle {
  font-size: 1rem;
  color: var(--text-dim);
  cursor: grab;
  user-select: none;
  line-height: 1;
  padding: 2px;
  transition: color var(--t-fast);
}

.narrative-drag-handle:hover { color: var(--accent); }
.narrative-drag-handle:active { cursor: grabbing; }

.narrative-seq-badge {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  letter-spacing: 0.08em;
  padding: 2px 7px;
  border-radius: 10px;
  background: var(--bg-overlay);
  border: 1px solid var(--border-dim);
  color: var(--accent);
  min-width: 28px;
  text-align: center;
  transition: all var(--t-fast);
}

.narrative-seq-badge[data-seq=""] {
  color: var(--text-dim);
  border-color: var(--border-dim);
  background: transparent;
}

/* ── Transition note field ───────────────────────────────────────────────── */

.transition-note-field {
  margin-top: var(--sp-3);
  padding-top: var(--sp-3);
  border-top: 1px dashed var(--border-dim);
}

.transition-note-field__label {
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
}

.transition-note-field__input {
  width: 100%;
  min-height: 64px;
  background: var(--bg-overlay);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-2) var(--sp-3);
  font-family: var(--font-body);
  font-size: 0.78rem;
  color: var(--text-secondary);
  resize: vertical;
  line-height: 1.5;
  transition: border-color var(--t-fast);
}

.transition-note-field__input:focus {
  outline: none;
  border-color: var(--accent-muted);
  color: var(--text-primary);
}

.transition-note-field__input::placeholder { color: var(--text-ghost); }


/* ============================================================================
   PHASE 11 — GEOINT: Time Slider, Tactical Map Modal, Coord Picker
   ============================================================================ */

/* ── Time Slider bar (below map header, above map canvas) ─────────────────── */

.map-time-bar {
  position: fixed;
  top: calc(var(--topbar-h) + 64px);     /* sits flush below map header */
  left: var(--sidebar-w);
  right: 0;
  z-index: 490;
  background: rgba(8, 13, 18, 0.95);
  border-bottom: 1px solid var(--border-dim);
  backdrop-filter: blur(8px);
  padding: var(--sp-2) var(--sp-6);
  transition: height 0.2s ease;
}

/* Push map further down when time bar is present */
#forge-map {
  top: calc(var(--topbar-h) + 64px + 48px) !important;
}
.map-info-panel {
  top: calc(var(--topbar-h) + 64px + 48px) !important;
}

.map-time-bar__inner {
  display: flex;
  align-items: center;
  gap: var(--sp-5);
  height: 32px;
}

.map-time-bar__left {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  flex-shrink: 0;
}

.map-time-bar__label {
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.map-time-bar__toggle {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  padding: 3px 8px;
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  background: transparent;
  color: var(--text-dim);
  cursor: pointer;
  transition: all var(--t-fast);
}

.map-time-bar__toggle:hover,
.map-time-bar__toggle--active {
  border-color: var(--accent-muted);
  color: var(--accent);
  background: var(--accent-glow);
}

/* ── Slider track + dual range thumbs ─────────────────────────────────────── */

.map-time-bar__slider-wrap {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  flex: 1;
  opacity: 0.35;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

.map-time-slider-wrap--active {
  opacity: 1;
  pointer-events: auto;
}

.map-time-bar__date {
  font-size: 0.6rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  white-space: nowrap;
  flex-shrink: 0;
}

.map-time-bar__track-wrap {
  position: relative;
  flex: 1;
  height: 20px;
  display: flex;
  align-items: center;
}

.map-time-bar__track {
  position: absolute;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--bg-elevated);
  border-radius: 2px;
}

.map-time-bar__fill {
  position: absolute;
  height: 3px;
  background: var(--accent-muted);
  border-radius: 2px;
  left: 0%;
  width: 100%;
  transition: left 0.05s, width 0.05s;
}

/* Dual-range slider: two overlapping <input type="range"> */
.map-time-range {
  position: absolute;
  left: 0;
  right: 0;
  width: 100%;
  height: 3px;
  background: transparent;
  appearance: none;
  -webkit-appearance: none;
  pointer-events: none;
  outline: none;
}

.map-time-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--bg-base);
  border: 2px solid var(--accent);
  cursor: ew-resize;
  pointer-events: auto;
  box-shadow: 0 0 6px rgba(200, 148, 58, 0.4);
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
}

.map-time-range::-moz-range-thumb {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: var(--bg-base);
  border: 2px solid var(--accent);
  cursor: ew-resize;
  pointer-events: auto;
}

.map-time-range::-webkit-slider-thumb:hover {
  border-color: var(--accent);
  box-shadow: 0 0 10px rgba(200, 148, 58, 0.6);
}

.map-time-bar__right {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  flex-shrink: 0;
}

.map-time-bar__active-range {
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  white-space: nowrap;
  min-width: 180px;
  text-align: right;
}

.map-time-bar__reset {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-dim);
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 2px 4px;
  transition: color var(--t-fast);
  line-height: 1;
}

.map-time-bar__reset:hover { color: var(--accent); }

.map-filter-label {
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-right: var(--sp-2);
}

/* ── Tactical Map Modal ───────────────────────────────────────────────────── */

.modal--wide .modal__box {
  max-width: 98vw;
}

.modal__box--tactical-map {
  width: min(1100px, 96vw);
  height: min(82vh, 680px);
  display: flex;
  flex-direction: column;
  padding: 0;
  overflow: hidden;
}

.modal__box--tactical-map .modal__header {
  padding: var(--sp-3) var(--sp-5);
  border-bottom: 1px solid var(--border-dim);
  border-radius: var(--r-md) var(--r-md) 0 0;
  flex-shrink: 0;
}

.tactical-map-header__right {
  display: flex;
  align-items: center;
  gap: var(--sp-4);
}

.tactical-map-stat {
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.08em;
}

.tactical-map-body {
  flex: 1;
  position: relative;
  overflow: hidden;
}

#js-tactical-map {
  width: 100%;
  height: 100%;
}

/* ── Tactical map legend overlay ─────────────────────────────────────────── */

.tactical-map-legend {
  position: absolute;
  bottom: var(--sp-5);
  left: var(--sp-5);
  background: rgba(8, 13, 18, 0.9);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-3) var(--sp-4);
  z-index: 800;
  min-width: 120px;
  backdrop-filter: blur(4px);
  pointer-events: none;
}

.tactical-map-legend__title {
  font-size: 0.55rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
}

.tactical-map-legend__items {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.tactical-legend-item {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
}

.tactical-legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1.5px solid;
  flex-shrink: 0;
  opacity: 0.8;
}

.tactical-legend-label {
  font-size: 0.62rem;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
}

.tactical-map-empty {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  z-index: 900;
  font-size: 0.78rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
}

/* Leaflet popup theme override for tactical map */
.tactical-popup-wrapper .leaflet-popup-content-wrapper {
  background: rgba(12, 18, 25, 0.97) !important;
  border: 1px solid rgba(255,255,255,0.1) !important;
  border-radius: 6px !important;
  box-shadow: 0 8px 32px rgba(0,0,0,0.6) !important;
  padding: 0 !important;
}

.tactical-popup-wrapper .leaflet-popup-content {
  margin: 14px 16px !important;
}

.tactical-popup-wrapper .leaflet-popup-tip-container { display: none !important; }

.tactical-popup-wrapper .leaflet-popup-close-button {
  color: rgba(255,255,255,0.4) !important;
  top: 6px !important;
  right: 8px !important;
  font-size: 1rem !important;
}

.tactical-popup-wrapper .leaflet-popup-close-button:hover {
  color: rgba(255,255,255,0.8) !important;
}

/* ── Coordinate Picker (edit_event.html) ─────────────────────────────────── */

.coord-field-group {
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  padding: var(--sp-4);
  margin-bottom: var(--sp-4);
}

.coord-field-group__header {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  margin-bottom: var(--sp-3);
  flex-wrap: wrap;
}

.coord-field-group__label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  flex: 1;
}

.coord-picker-trigger {
  color: var(--accent) !important;
  border-color: var(--accent-muted) !important;
}

.coord-preview {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  padding: var(--sp-2) var(--sp-3);
  background: var(--bg-overlay);
  border-radius: var(--r-sm);
  border: 1px solid var(--border-dim);
  margin-top: var(--sp-2);
}

.coord-preview--empty { opacity: 0.5; }

.coord-preview__icon { font-size: 0.8rem; }

.coord-preview__text {
  font-size: 0.68rem;
  color: var(--text-secondary);
  letter-spacing: 0.04em;
  flex: 1;
}

.coord-preview__map-link {
  font-size: 0.62rem;
  color: var(--text-dim);
  text-decoration: none;
  letter-spacing: 0.06em;
  white-space: nowrap;
  transition: color var(--t-fast);
}

.coord-preview__map-link:hover { color: var(--accent); }

/* ── Coordinate picker modal ─────────────────────────────────────────────── */

.modal--wide.modal--fullscreen-map .modal__backdrop { display: block; }

.modal__box--coord-picker {
  width: min(960px, 96vw);
  height: min(80vh, 620px);
  display: flex;
  flex-direction: column;
  padding: 0;
  overflow: hidden;
}

.modal__box--coord-picker .modal__header {
  padding: var(--sp-3) var(--sp-5);
  border-bottom: 1px solid var(--border-dim);
  border-radius: var(--r-md) var(--r-md) 0 0;
  flex-shrink: 0;
}

.coord-modal-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.coord-modal-hint {
  padding: var(--sp-2) var(--sp-5);
  font-size: 0.65rem;
  color: var(--text-dim);
  letter-spacing: 0.06em;
  background: var(--bg-elevated);
  border-bottom: 1px solid var(--border-dim);
  flex-shrink: 0;
}

.coord-modal-layout {
  display: grid;
  grid-template-columns: 1fr 260px;
  flex: 1;
  overflow: hidden;
}

.coord-modal-map-wrap {
  position: relative;
  overflow: hidden;
}

#js-picker-map {
  width: 100%;
  height: 100%;
}

.coord-modal-sidebar {
  padding: var(--sp-4);
  border-left: 1px solid var(--border-dim);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  background: var(--bg-surface);
}

.coord-modal-sidebar .form-group { margin-bottom: 0; }

.coord-search-row {
  display: flex;
  gap: var(--sp-2);
  align-items: stretch;
}

.coord-modal-actions {
  display: flex;
  gap: var(--sp-2);
  margin-top: auto;
  padding-top: var(--sp-3);
}

.coord-modal-actions .btn { flex: 1; }

.coord-modal-presets {
  padding-top: var(--sp-3);
  border-top: 1px solid var(--border-dim);
}

.coord-modal-presets__label {
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: var(--sp-2);
}

.coord-modal-presets__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-1);
}

.coord-preset-btn {
  font-size: 0.62rem;
  letter-spacing: 0.04em;
  padding: 4px var(--sp-2);
  background: var(--bg-elevated);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  color: var(--text-secondary);
  cursor: pointer;
  text-align: center;
  transition: all var(--t-fast);
}

.coord-preset-btn:hover {
  border-color: var(--accent-muted);
  color: var(--accent);
  background: var(--accent-glow);
}

/* Custom picker marker */
.forge-picker-marker svg { overflow: visible; }

/* ── Responsive: hide time bar on small viewports ────────────────────────── */
@media (max-width: 860px) {
  .map-time-bar__slider-wrap { display: none; }
  .map-time-bar__right       { display: none; }

  .coord-modal-layout {
    grid-template-columns: 1fr;
    grid-template-rows:    1fr auto;
  }
  .coord-modal-sidebar {
    border-left:  none;
    border-top:   1px solid var(--border-dim);
    max-height:   220px;
  }
}


/* ============================================================================
   PHASE 12 — Intelligence Graph Engine (Vis-Network)
   ─────────────────────────────────────────────────────────────────────────
   IMPORTANT: All .graph-bar*, .graph-panel*, .gpanel__*, .graph-legend*,
   .graph-loading*, .graph-stat*, .graph-icon-btn, .graph-canvas-wrap CSS
   from Phase 6 is PRESERVED and REUSED.  This section adds only the new
   classes needed for Vis-Network integration.
   ============================================================================ */

/* ── Vis-Network canvas fill inside the existing .graph-canvas-wrap ─────── */

#js-vis-canvas {
  position: absolute;
  inset: 0;
  width:  100% !important;
  height: 100% !important;
  background: transparent;
  /* Vis-Network injects its own <canvas> here; we just make the div fill the frame */
}

/* Override vis-network's injected canvas element */
#js-vis-canvas > canvas {
  display: block;
  width:   100% !important;
  height:  100% !important;
}

/* ── Vis-Network tooltip (replaces Vis's default white popup) ────────────── */

div.vis-tooltip {
  background: rgba(8, 13, 18, 0.95)  !important;
  border:     1px solid rgba(200, 148, 58, 0.35) !important;
  border-radius: var(--r-sm) !important;
  color:      var(--text-secondary) !important;
  font-family:var(--font-mono) !important;
  font-size:  0.68rem !important;
  line-height: 1.55 !important;
  padding:    var(--sp-2) var(--sp-3) !important;
  box-shadow: 0 4px 20px rgba(0,0,0,0.6) !important;
  max-width:  260px !important;
  white-space: pre-line !important;
  pointer-events: none !important;
  z-index: 9999 !important;
}

/* ── Vis-Network selection ring colour  (override blue default) ──────────── */

div.vis-network canvas {
  outline: none;  /* suppress browser focus outline on canvas */
}

/* ── Stabilisation progress badge ───────────────────────────────────────── */

.vis-stabilising {
  position: fixed;
  right:   var(--sp-5);
  bottom:  var(--sp-5);
  z-index: 700;
  padding: var(--sp-2) var(--sp-4);
  background: rgba(8, 13, 18, 0.90);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-sm);
  backdrop-filter: blur(4px);
  pointer-events: none;
  animation: fadeIn 0.2s ease;
}

.vis-stabilising .mono {
  font-size:    0.62rem;
  letter-spacing: 0.08em;
  color:        var(--accent);
  text-transform: uppercase;
}

/* ── Side-panel connected-node list  (.gpanel__edge-*) ───────────────────── */

.gpanel__section--edges {
  padding-bottom: var(--sp-3);
}

.gpanel__edge-row {
  display:        flex;
  align-items:    center;
  gap:            var(--sp-2);
  padding:        5px 0;
  border-bottom:  1px solid rgba(255,255,255,0.04);
}

.gpanel__edge-row:last-of-type { border-bottom: none; }

.gpanel__edge-dot {
  width:         8px;
  height:        8px;
  border-radius: 50%;
  flex-shrink:   0;
  border:        1.5px solid;
}

.gpanel__edge-dot--actor    { background: #1a2a4a; border-color: #7aa2f7; }
.gpanel__edge-dot--event    { background: #3a1a22; border-color: #f7768e; border-radius: 1px; }
.gpanel__edge-dot--artifact { background: #1a2a14; border-color: #9ece6a; }

.gpanel__edge-label {
  flex:          1;
  font-size:     0.72rem;
  color:         var(--text-secondary);
  text-decoration: none;
  white-space:   nowrap;
  overflow:      hidden;
  text-overflow: ellipsis;
  transition:    color var(--t-fast);
}

.gpanel__edge-label:hover { color: var(--accent); }

.gpanel__edge-dir {
  font-size:  0.65rem;
  color:      var(--text-ghost);
  flex-shrink: 0;
}

.gpanel__edge-role {
  font-family:    var(--font-mono);
  font-size:      0.6rem;
  letter-spacing: 0.04em;
  color:          var(--accent-muted);
  background:     var(--accent-glow);
  border:         1px solid rgba(200, 148, 58, 0.20);
  border-radius:  var(--r-sm);
  padding:        1px 5px;
  white-space:    nowrap;
  flex-shrink:    0;
}

.gpanel__edge-more {
  font-size:      0.6rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color:          var(--text-ghost);
  padding-top:    var(--sp-2);
}

/* ── Physics-toggle visual state (already covered by .graph-toggle--active,
      this just gives the amber dot a glow when active) ───────────────────── */

#js-physics-toggle.graph-toggle--active .graph-toggle__dot {
  box-shadow: 0 0 6px rgba(200, 148, 58, 0.6);
}

/* ── Override vis-network's injected navigation buttons (we hide them) ────── */

.vis-button { display: none !important; }

/* ── Responsive tweaks for the graph on small viewports ─────────────────── */

@media (max-width: 900px) {
  .vis-stabilising { right: var(--sp-3); bottom: var(--sp-3); }
}


/* ============================================================================
   PHASE 13 — FORAGE Signal Monitor
   signal table · status badges · summary bar · filter tabs ·
   promote/dismiss actions · empty state
   ============================================================================ */

/* ── Summary bar ─────────────────────────────────────────────────────────── */

.signal-summary-bar {
  display:        flex;
  align-items:    center;
  gap:            var(--sp-4);
  padding:        var(--sp-4) var(--sp-5);
  margin-bottom:  var(--sp-4);
  background:     var(--bg-surface);
  border:         1px solid var(--border-dim);
  border-radius:  var(--r-sm);
}

.signal-summary-bar__sep {
  width:          1px;
  height:         28px;
  background:     var(--border-dim);
  flex-shrink:    0;
}

.signal-summary-bar__item {
  display:        flex;
  flex-direction: column;
  align-items:    center;
  gap:            2px;
  flex-shrink:    0;
}

.signal-summary-bar__val {
  font-family:    var(--font-display);
  font-weight:    700;
  font-size:      1.3rem;
  color:          var(--accent);
  line-height:    1;
}

.signal-summary-bar__val--raw       { color: #c8943a; }
.signal-summary-bar__val--reviewed  { color: #7aa2f7; }
.signal-summary-bar__val--promoted  { color: #9ece6a; }
.signal-summary-bar__val--dismissed { color: var(--text-dim); }

.signal-summary-bar__label {
  font-size:      0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--text-dim);
}

/* ── Filter tab bar ──────────────────────────────────────────────────────── */

.signal-filter-bar {
  display:        flex;
  align-items:    center;
  gap:            var(--sp-2);
  margin-bottom:  var(--sp-4);
  flex-wrap:      wrap;
}

.signal-filter-btn {
  display:        inline-flex;
  align-items:    center;
  gap:            var(--sp-2);
  font-family:    var(--font-mono);
  font-size:      0.68rem;
  letter-spacing: 0.06em;
  padding:        5px var(--sp-4);
  border:         1px solid var(--border-dim);
  border-radius:  2px;
  color:          var(--text-dim);
  background:     transparent;
  cursor:         pointer;
  transition:     background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
}

.signal-filter-btn:hover {
  color:          var(--text-secondary);
  border-color:   var(--border-mid);
}

.signal-filter-btn--active {
  color:          var(--text-primary);
  border-color:   var(--accent-muted);
  background:     var(--accent-glow);
}

/* ── Signal status dot (inline in filter buttons) ────────────────────────── */

.signal-status-dot {
  width:          7px;
  height:         7px;
  border-radius:  50%;
  flex-shrink:    0;
}

.signal-status-dot--raw       { background: #c8943a; }
.signal-status-dot--reviewed  { background: #7aa2f7; }
.signal-status-dot--promoted  { background: #9ece6a; }
.signal-status-dot--dismissed { background: var(--text-ghost); }

/* ── Signal table wrapper ────────────────────────────────────────────────── */

.signal-table-wrap {
  overflow-x: auto;
  border:     1px solid var(--border-dim);
  border-radius: var(--r-sm);
  background: var(--bg-surface);
}

/* ── Signal table ────────────────────────────────────────────────────────── */

.signal-table {
  width:           100%;
  border-collapse: collapse;
  font-size:       0.8rem;
}

/* ── Header row ──────────────────────────────────────────────────────────── */

.signal-table__th {
  padding:         var(--sp-2) var(--sp-3);   /* Phase 15.5: tighter for density */
  font-family:     var(--font-mono);
  font-size:       0.6rem;
  letter-spacing:  0.1em;
  text-transform:  uppercase;
  color:           var(--text-dim);
  text-align:      left;
  white-space:     nowrap;
  border-bottom:   1px solid var(--border-dim);
  background:      var(--bg-elevated);
}

.signal-table__th--status  { width: 88px;  }
.signal-table__th--source  { width: 70px;  }
.signal-table__th--title   { min-width: 200px; }
.signal-table__th--content { min-width: 240px; }
.signal-table__th--coords  { width: 110px; }
.signal-table__th--time    { width: 150px; }
.signal-table__th--actions { width: 160px; }

/* ── Data rows ───────────────────────────────────────────────────────────── */

.signal-row {
  transition: background var(--t-fast);
}

.signal-row:hover {
  background: var(--bg-hover);
}

.signal-row + .signal-row {
  border-top: 1px solid rgba(255,255,255,0.04);
}

/* Subtle tint for already-processed rows */
.signal-row[data-status="promoted"]  { opacity: 0.65; }
.signal-row[data-status="dismissed"] { opacity: 0.40; }

.signal-table__td {
  padding:        var(--sp-2) var(--sp-3);    /* Phase 15.5: tighter for density */
  vertical-align: top;
  color:          var(--text-secondary);
}

.signal-table__td--title {
  color: var(--text-primary);
}

/* ── Cell sub-elements ───────────────────────────────────────────────────── */

.signal-title {
  font-size:   0.8rem;
  font-weight: 500;
  line-height: 1.35;
  color:       var(--text-primary);
  margin-bottom: 2px;
}

.signal-external-id {
  font-size:   0.6rem;
  color:       var(--text-ghost);
  letter-spacing: 0.04em;
  white-space: nowrap;
  overflow:    hidden;
  text-overflow: ellipsis;
  max-width:   220px;
}

.signal-coords {
  font-size:   0.7rem;
  color:       var(--text-dim);
  white-space: nowrap;
}

.signal-ts {
  font-size:   0.68rem;
  color:       var(--text-dim);
  white-space: nowrap;
}

/* ── Status badge ────────────────────────────────────────────────────────── */

.signal-status-badge {
  display:        inline-flex;
  align-items:    center;
  font-family:    var(--font-mono);
  font-size:      0.6rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding:        2px 7px;
  border-radius:  2px;
  border:         1px solid;
  white-space:    nowrap;
}

.signal-status-badge--raw {
  background:   rgba(200, 148, 58, 0.10);
  color:        #d4a84a;
  border-color: rgba(200, 148, 58, 0.35);
}

.signal-status-badge--reviewed {
  background:   rgba(122, 162, 247, 0.10);
  color:        #9ab8ff;
  border-color: rgba(122, 162, 247, 0.30);
}

.signal-status-badge--promoted {
  background:   rgba(158, 206, 106, 0.10);
  color:        #9ece6a;
  border-color: rgba(158, 206, 106, 0.30);
}

.signal-status-badge--dismissed {
  background:   rgba(255, 255, 255, 0.03);
  color:        var(--text-ghost);
  border-color: var(--border-dim);
}

/* ── Source tag ──────────────────────────────────────────────────────────── */

.signal-source-tag {
  display:        inline-flex;
  font-family:    var(--font-mono);
  font-size:      0.62rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding:        2px 6px;
  background:     var(--bg-overlay);
  border:         1px solid var(--border-dim);
  border-radius:  2px;
  color:          var(--text-secondary);
  white-space:    nowrap;
}

/* ── Action buttons in table ─────────────────────────────────────────────── */

.signal-actions {
  display:    flex;
  flex-wrap:  wrap;
  gap:        var(--sp-2);
  align-items: flex-start;
}

.btn--promote {
  background:   rgba(158, 206, 106, 0.10);
  border-color: rgba(158, 206, 106, 0.35);
  color:        #9ece6a;
  text-decoration: none;
}

.btn--promote:hover {
  background:   rgba(158, 206, 106, 0.18);
  border-color: #9ece6a;
  color:        #b8e48a;
}

.btn--dismiss {
  background:   transparent;
  border-color: var(--border-dim);
  color:        var(--text-dim);
  cursor:       pointer;
}

.btn--dismiss:hover {
  border-color: rgba(200, 80, 80, 0.5);
  color:        #e06060;
}

.btn--dismiss:disabled {
  opacity: 0.4;
  cursor:  default;
}

.signal-promoted-label {
  font-size:      0.65rem;
  letter-spacing: 0.06em;
  color:          #9ece6a;
  opacity:        0.7;
}

/* ── Empty-after-filter notice ───────────────────────────────────────────── */

.signal-empty-filter {
  display:         flex;
  justify-content: center;
  padding:         var(--sp-8) 0;
}

/* ── Empty state (no signals at all) ─────────────────────────────────────── */

.empty-state {
  display:         flex;
  flex-direction:  column;
  align-items:     center;
  justify-content: center;
  gap:             var(--sp-4);
  padding:         var(--sp-10) var(--sp-6);
  text-align:      center;
}

.empty-state__icon {
  font-size: 2.5rem;
  color:     var(--text-ghost);
  line-height: 1;
}

.empty-state__title {
  font-family: var(--font-display);
  font-weight: 600;
  font-size:   1rem;
  color:       var(--text-secondary);
}

.empty-state__body {
  font-size: 0.8rem;
  color:     var(--text-dim);
  max-width: 420px;
  line-height: 1.6;
}

.empty-state__code {
  font-size:   0.72rem;
  padding:     var(--sp-3) var(--sp-5);
  background:  var(--bg-elevated);
  border:      1px solid var(--border-dim);
  border-radius: var(--r-sm);
  color:       var(--accent);
  letter-spacing: 0.04em;
}

/* ── Promote form — form-card, form-group, form-row re-use base styles ────── */

/* Coordinates hint note inside the promote form */
.signal-promote-coords-note {
  font-size:      0.68rem;
  letter-spacing: 0.04em;
  color:          var(--text-dim);
  padding:        var(--sp-2) var(--sp-4);
  background:     rgba(158, 206, 106, 0.06);
  border:         1px solid rgba(158, 206, 106, 0.18);
  border-radius:  var(--r-sm);
  margin-bottom:  var(--sp-5);
}

.signal-promote-coords-note strong {
  color:  #9ece6a;
  font-weight: 600;
}

/* ── Responsive ──────────────────────────────────────────────────────────── */

@media (max-width: 1100px) {
  .signal-table__td--content { display: none; }
  .signal-table__th--content { display: none; }
}

@media (max-width: 860px) {
  .signal-table__td--coords { display: none; }
  .signal-table__th--coords { display: none; }
  .signal-summary-bar { flex-wrap: wrap; gap: var(--sp-3); }
}


/* ============================================================================
   CSS GAP-FILL — missing class definitions identified by cross-reference audit
   Each block notes the template file that uses the class and why it was absent.
   ============================================================================ */

/* ── page-header__meta ───────────────────────────────────────────────────────
   Used in: signals.html, admin_event_new.html
   The page-header block had __eyebrow, __title, __sub, __actions but not __meta.
   Role: secondary descriptive paragraph beneath the page title.           ── */

.page-header__meta {
  font-size:   0.82rem;
  color:       var(--text-secondary);
  line-height: 1.65;
  margin-top:  var(--sp-2);
  max-width:   640px;
}

/* ── search-result__snippet ──────────────────────────────────────────────────
   Used in: search.html
   CSS had .search-result__excerpt; template uses __snippet (name drift).
   Both render the same role: highlighted FTS excerpt below a search hit.  ── */

.search-result__snippet {
  font-size:   0.78rem;
  color:       var(--text-secondary);
  line-height: 1.65;
  margin-top:  var(--sp-2);
  /* Highlight <mark> tags injected by the FTS snippet() function */
}

.search-result__snippet mark {
  background: rgba(200, 148, 58, 0.22);
  color:      var(--accent-bright);
  padding:    0 2px;
  border-radius: 2px;
}

/* ── dossier-header__subject ─────────────────────────────────────────────────
   Used in: dossier.html
   The dossier-header family had strip/classification/eyebrow/title/meta-row
   but not __subject — the wrapper div that groups the eyebrow + title block.  */

.dossier-header__subject {
  flex:        1;
  min-width:   0;
}

/* ── graph-toggle--actor / --event ───────────────────────────────────────────
   Used in: graph.html (Phase 12)
   These are modifier classes on .graph-toggle buttons in the control bar.
   They carry no extra visual rules beyond the base .graph-toggle styles —
   they exist as data/JS hooks and for future per-kind styling.            ── */

.graph-toggle--actor,
.graph-toggle--event {
  /* Intentionally no additional rules — inherits from .graph-toggle.
     Class present for semantic targeting and potential future differentiation. */
}

/* ── signal-table__td--time / --actions ─────────────────────────────────────
   Used in: signals.html
   signal-table__td--title and --content had explicit rules; --time and
   --actions were missing their column-level overrides.                   ── */

.signal-table__td--time {
  white-space: nowrap;
  color:       var(--text-dim);
}

.signal-table__td--actions {
  white-space: nowrap;
  vertical-align: middle;
}

/* ── map-popup (base wrapper) ────────────────────────────────────────────────
   Used in: map.html
   CSS had .map-popup__header, __title, __body etc. but not the root
   .map-popup wrapper itself (used on the Leaflet popup content div).     ── */

.map-popup {
  min-width:  220px;
  max-width:  300px;
  font-family: var(--font-sans);
}

/* ── tactical-popup ──────────────────────────────────────────────────────────
   Used in: case_detail.html (Phase 11 tactical map)
   CSS had .tactical-popup-wrapper (the Leaflet wrapper override) but not
   .tactical-popup itself (the inner content div with inline styles).     ── */

.tactical-popup {
  font-family: var(--font-sans);
  font-size:   0.78rem;
  line-height: 1.55;
}

/* ── case-create-form (root wrapper) ─────────────────────────────────────────
   Used in: cases.html
   CSS had case-create-form__row / __input / __select / __textarea but not
   the root form wrapper class.                                           ── */

.case-create-form {
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-3);
}


/* ── actor-card__type ────────────────────────────────────────────────────────
   actors.html — the actor type label (person/institution/etc) inside each
   card. Sibling to actor-card__name and actor-card__desc which exist.    ── */

.actor-card__type {
  font-family:    var(--font-mono);
  font-size:      0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--accent);
  margin-bottom:  var(--sp-1);
  opacity:        0.85;
}

/* ── event-row__artifact-count ───────────────────────────────────────────────
   events.html — artifact count pill on each event row. Sibling to
   event-row__date, __title, __meta, __count which exist.                 ── */

.event-row__artifact-count {
  font-family:    var(--font-mono);
  font-size:      0.65rem;
  color:          var(--text-dim);
  letter-spacing: 0.04em;
}


/* ============================================================================
   Phase 14 — Pattern Detection & Alert Engine UI
   Bell icon · Priority flag · Cluster badge · Priority Only toggle
   ============================================================================ */

/* ── Topbar alert bell ────────────────────────────────────────────────────────
   Sits between the search form and the UTC clock.
   Uses position:relative so the count dot can be anchored absolutely.    ── */

.topbar__bell {
  position:      relative;
  display:       flex;
  align-items:   center;
  justify-content: center;
  width:         34px;
  height:        34px;
  border-radius: var(--r-sm);
  color:         var(--text-dim);
  text-decoration: none;
  flex-shrink:   0;
  transition:    color var(--t-fast), background var(--t-fast);
}

.topbar__bell:hover {
  color:       var(--text-secondary);
  background:  var(--bg-elevated);
}

/* Active state — priority signals exist */
.topbar__bell--active {
  color: #e05c5c;
  animation: bell-glow 2.8s ease-in-out infinite;
}

.topbar__bell--active:hover {
  color:      #e87070;
  background: rgba(224, 92, 92, 0.1);
}

.topbar__bell-icon {
  display: block;
  flex-shrink: 0;
}

/* Count dot — floats top-right of the bell icon */
.topbar__bell-dot {
  position:      absolute;
  top:           3px;
  right:         3px;
  min-width:     16px;
  height:        16px;
  padding:       0 3px;
  background:    #e05c5c;
  color:         #fff;
  font-family:   var(--font-mono);
  font-size:     0.58rem;
  font-weight:   700;
  line-height:   16px;
  text-align:    center;
  border-radius: 8px;
  pointer-events: none;
  box-shadow:    0 0 0 2px var(--bg-void);
}

/* Pulse glow keyframe — ambient red shimmer on the bell when active */
@keyframes bell-glow {
  0%, 100% { filter: drop-shadow(0 0 0px rgba(224, 92, 92, 0));   }
  50%       { filter: drop-shadow(0 0 5px rgba(224, 92, 92, 0.65)); }
}

/* ── signal-summary-bar Phase 14 value colours ───────────────────────────────  */

.signal-summary-bar__val--priority { color: #e05c5c; }
.signal-summary-bar__val--cluster  { color: #bb86fc; }

/* ── Filter bar spacer (pushes Priority Only to right edge) ──────────────────  */

.signal-filter-spacer {
  flex: 1;
}

/* ── Priority Only toggle button ──────────────────────────────────────────────
   Shares .signal-filter-btn base styles; --priority modifier adds red accent. */

.signal-filter-btn--priority {
  border-color: rgba(224, 92, 92, 0.3);
  color:        #e05c5c;
  gap:          var(--sp-2);
}

.signal-filter-btn--priority:hover {
  background:   rgba(224, 92, 92, 0.08);
  border-color: rgba(224, 92, 92, 0.55);
}

/* Active (pressed) state */
.signal-filter-btn--priority-active {
  background:   rgba(224, 92, 92, 0.15) !important;
  border-color: #e05c5c !important;
  color:        #e87070 !important;
}

/* Small red dot inside the Priority Only button */
.signal-priority-dot {
  display:       inline-block;
  width:         7px;
  height:        7px;
  border-radius: 50%;
  background:    #e05c5c;
  flex-shrink:   0;
  animation:     priority-dot-pulse 2.4s ease-in-out infinite;
}

@keyframes priority-dot-pulse {
  0%, 100% { box-shadow: 0 0 0 0   rgba(224, 92, 92, 0.5); }
  50%       { box-shadow: 0 0 0 4px rgba(224, 92, 92, 0);   }
}

/* ── Priority row highlight ───────────────────────────────────────────────────
   A left-edge accent stripe on rows where is_priority = 1.               ── */

.signal-row--priority {
  border-left: 3px solid rgba(224, 92, 92, 0.5);
  background:  rgba(224, 92, 92, 0.03);
}

.signal-row--priority:hover {
  background: rgba(224, 92, 92, 0.06);
}

/* ── Phase 15.5: Low-relevance dimming ───────────────────────────────────────
   Applied to raw, non-priority signals — recedes into the background when
   high-volume GDELT traffic floods the table.                              ── */

.signal-row--low-relevance {
  opacity: 0.6;
}
.signal-row--low-relevance:hover {
  opacity: 1;
  transition: opacity var(--t-fast);
}

/* ── Phase 15.5: Source filter controls in filter bar ───────────────────────  */

.signal-source-filters {
  display:     flex;
  align-items: center;
  gap:         var(--sp-1);
  margin-right: var(--sp-2);
}

.signal-source-filter-label {
  font-size:      0.6rem;
  letter-spacing: 0.1em;
  color:          var(--text-ghost);
  margin-right:   var(--sp-1);
  text-transform: uppercase;
}

/* Source-specific active states mirror badge colours */
.signal-source-filter-btn {
  font-size:      0.65rem;
  padding:        2px 7px;
  border-radius:  3px;
  border:         1px solid rgba(255,255,255,0.10);
  background:     transparent;
  color:          var(--text-dim);
  cursor:         pointer;
  font-family:    var(--font-mono);
  letter-spacing: 0.05em;
  transition:     all var(--t-fast);
}
.signal-source-filter-btn:hover {
  border-color: rgba(255,255,255,0.22);
  color:        var(--text-secondary);
}
.signal-source-filter-btn--gdelt.signal-source-filter-btn--active {
  background:  rgba(99, 102, 241, 0.15);
  color:       #818cf8;
  border-color: rgba(99, 102, 241, 0.45);
}
.signal-source-filter-btn--gdacs.signal-source-filter-btn--active {
  background:  rgba(16, 185, 129, 0.12);
  color:       #34d399;
  border-color: rgba(16, 185, 129, 0.40);
}
.signal-source-filter-btn--rss.signal-source-filter-btn--active {
  background:  rgba(200, 148, 58, 0.12);
  color:       var(--accent);
  border-color: rgba(200, 148, 58, 0.40);
}
.signal-source-filter-btn--interpol.signal-source-filter-btn--active {
  background:  rgba(245, 158, 11, 0.12);
  color:       #fbbf24;
  border-color: rgba(245, 158, 11, 0.40);
}

/* ── Source badges in summary bar ─────────────────────────────────────────── */

.signal-summary-bar__sources {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  flex-wrap:   wrap;
}

/* ── Priority flag glyph (⚑) inside the status cell ─────────────────────────  */

.signal-status-cell {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
}

.signal-priority-flag {
  font-size:   0.82rem;
  color:       #e05c5c;
  line-height: 1;
  flex-shrink: 0;
  animation:   priority-flag-fade 2.8s ease-in-out infinite;
}

@keyframes priority-flag-fade {
  0%, 100% { opacity: 1;    }
  50%       { opacity: 0.55; }
}

/* ── Cluster badge ────────────────────────────────────────────────────────────
   Compact truncated-UUID pill in the Cluster column.                     ── */

.signal-table__th--cluster { width: 96px; }

.signal-table__td--cluster {
  white-space: nowrap;
}

.signal-cluster-badge {
  display:       inline-block;
  padding:       2px 6px;
  background:    rgba(187, 134, 252, 0.1);
  border:        1px solid rgba(187, 134, 252, 0.25);
  border-radius: var(--r-sm);
  color:         #bb86fc;
  font-size:     0.62rem;
  letter-spacing: 0.04em;
  cursor:        default;
  white-space:   nowrap;
}

.signal-cluster-badge:hover {
  background: rgba(187, 134, 252, 0.18);
  border-color: rgba(187, 134, 252, 0.45);
}


/* ============================================================================
   Phase 15 — Situational Dashboard: Map Signal Layer
   Signal markers · pulse animation · cluster centroids · layer control
   ============================================================================ */

/* ── Pulsing marker — priority signals (Phase 15.5: CSS var for source colour) ─
   A CSS-only animated dot injected via L.divIcon html.
   --pulse-col is set inline by makeSignalIcon() so non-red sources pulse
   in their own brand colour.                                             ── */

.forge-signal-pulse {
  position:      relative;
  width:         14px;
  height:        14px;
  border-radius: 50%;
  background:    var(--pulse-col, #e05c5c);
  box-shadow:    0 0 0 0 var(--pulse-col, rgba(224, 92, 92, 0.7));
  animation:     signal-pulse-ring 1.8s ease-out infinite;
}

.forge-signal-pulse::before {
  content:       '';
  position:      absolute;
  inset:         -5px;
  border-radius: 50%;
  border:        1.5px solid var(--pulse-col, rgba(224, 92, 92, 0.45));
  opacity:       0.55;
  animation:     signal-pulse-outer 1.8s ease-out infinite;
  animation-delay: 0.3s;
}

.forge-signal-pulse::after {
  content:       '';
  position:      absolute;
  inset:         -10px;
  border-radius: 50%;
  border:        1px solid var(--pulse-col, rgba(224, 92, 92, 0.2));
  opacity:       0.25;
  animation:     signal-pulse-outer 1.8s ease-out infinite;
  animation-delay: 0.6s;
}

@keyframes signal-pulse-ring {
  0%   { box-shadow: 0 0 0 0   rgba(224, 92, 92, 0.7); }
  70%  { box-shadow: 0 0 0 14px rgba(224, 92, 92, 0);   }
  100% { box-shadow: 0 0 0 0   rgba(224, 92, 92, 0);   }
}

@keyframes signal-pulse-outer {
  0%   { transform: scale(1);   opacity: 0.6; }
  100% { transform: scale(1.8); opacity: 0;   }
}

/* ── Cluster centroid marker ──────────────────────────────────────────────────
   Leaflet divIcon container — needs pointer-events passthrough.          ── */

.forge-cluster-centroid {
  background:    transparent !important;
  border:        none !important;
  cursor:        pointer;
}

/* ── Layer control — dark-first classified aesthetic ──────────────────────────
   Override Leaflet's default white-panel layer control to match FORGE.   ── */

.leaflet-control-layers {
  background:    var(--bg-elevated) !important;
  border:        1px solid var(--border-mid) !important;
  border-radius: var(--r-md) !important;
  box-shadow:    0 4px 24px rgba(0, 0, 0, 0.55) !important;
  min-width:     180px;
  overflow:      hidden;
}

.leaflet-control-layers-expanded {
  padding: 10px 14px 12px !important;
}

.leaflet-control-layers-toggle {
  background-color: var(--bg-elevated) !important;
  border:           1px solid var(--border-dim) !important;
  border-radius:    var(--r-sm) !important;
}

/* Section heading "Overlays" */
.leaflet-control-layers-separator {
  border-top:    1px solid var(--border-dim) !important;
  margin:        6px 0 !important;
}

.leaflet-control-layers-overlays label,
.leaflet-control-layers-base label {
  display:        flex !important;
  align-items:    center !important;
  gap:            8px;
  padding:        4px 0;
  font-family:    var(--font-mono) !important;
  font-size:      0.7rem !important;
  letter-spacing: 0.05em !important;
  color:          var(--text-secondary) !important;
  cursor:         pointer !important;
  transition:     color var(--t-fast) !important;
}

.leaflet-control-layers-overlays label:hover,
.leaflet-control-layers-base label:hover {
  color: var(--text-primary) !important;
}

/* Checkbox styling */
.leaflet-control-layers input[type="checkbox"] {
  accent-color:  var(--accent);
  width:         13px;
  height:        13px;
  cursor:        pointer;
}

/* "Layers" title injected by Leaflet — hide default, shown via ::before */
.leaflet-control-layers-list::before {
  content:        'LAYERS';
  display:        block;
  font-family:    var(--font-mono);
  font-size:      0.58rem;
  letter-spacing: 0.14em;
  color:          var(--text-ghost);
  margin-bottom:  8px;
  text-transform: uppercase;
}

/* ── Signal popup panels — additional popup-specific styles ───────────────────
   The signal panels re-use map-popup__ classes but need a few extras.    ── */

.map-popup .signal-status-badge { font-size: 0.6rem; padding: 1px 5px; }
.map-popup .signal-source-tag   { font-size: 0.6rem; padding: 1px 5px; }
.map-popup .signal-cluster-badge{ font-size: 0.62rem; }
.map-popup .signal-priority-flag{ font-size: 0.75rem; color: #e05c5c; }
.map-popup .map-popup__footer   { flex-direction: column; gap: var(--sp-2); align-items: stretch; }

/* ============================================================================
   Phase 16 — Synthesis & Case Linkage
   Signal linked badge · Pin modal · Case detail page
   ============================================================================ */

/* ── ⬡ Linked badge in Signal Monitor rows ──────────────────────────────────── */

.signal-linked-badge {
  display:       inline-flex;
  align-items:   center;
  justify-content: center;
  font-size:     0.72rem;
  color:         #818cf8;
  cursor:        default;
  line-height:   1;
  flex-shrink:   0;
  animation:     linked-badge-pulse 3s ease-in-out infinite;
}

@keyframes linked-badge-pulse {
  0%, 100% { opacity: 1;    }
  50%       { opacity: 0.55; }
}

/* ── Linked Only filter button active state ─────────────────────────────────── */

.signal-filter-btn--linked-active {
  color:        #818cf8 !important;
  border-color: rgba(99, 102, 241, 0.45) !important;
  background:   rgba(99, 102, 241, 0.12) !important;
}

/* ── Pin-to-Case modal ───────────────────────────────────────────────────────── */

.signal-pin-modal {
  position:        fixed;
  inset:           0;
  z-index:         900;
  display:         none;
  align-items:     center;
  justify-content: center;
  background:      rgba(2, 6, 10, 0.72);
  backdrop-filter: blur(4px);
}
.signal-pin-modal--open {
  display: flex;
}

.signal-pin-modal__box {
  width:         420px;
  max-width:     calc(100vw - var(--sp-8));
  background:    var(--bg-surface);
  border:        1px solid var(--border-mid);
  border-radius: var(--r-md);
  padding:       var(--sp-5);
  box-shadow:    0 24px 64px rgba(0,0,0,0.6);
}

.signal-pin-modal__header {
  display:         flex;
  justify-content: space-between;
  align-items:     center;
  margin-bottom:   var(--sp-3);
}

.signal-pin-modal__title {
  font-size:      0.62rem;
  letter-spacing: 0.12em;
  color:          var(--text-dim);
  text-transform: uppercase;
}

.signal-pin-modal__close {
  background:   transparent;
  border:       none;
  color:        var(--text-ghost);
  font-size:    0.8rem;
  cursor:       pointer;
  padding:      2px 4px;
  line-height:  1;
  transition:   color var(--t-fast);
}
.signal-pin-modal__close:hover { color: var(--text-primary); }

.signal-pin-modal__signal-title {
  font-size:     0.82rem;
  color:         var(--text-primary);
  line-height:   1.4;
  margin-bottom: var(--sp-3);
  padding-bottom: var(--sp-3);
  border-bottom: 1px solid var(--border-dim);
}

.signal-pin-modal__cases {
  max-height:    220px;
  overflow-y:    auto;
  margin-bottom: var(--sp-3);
  display:       flex;
  flex-direction: column;
  gap:           var(--sp-1);
}

.signal-pin-modal__case-item {
  display:       flex;
  align-items:   center;
  gap:           var(--sp-2);
  padding:       var(--sp-2) var(--sp-3);
  border-radius: var(--r-sm);
  border:        1px solid var(--border-dim);
  cursor:        pointer;
  transition:    all var(--t-fast);
}
.signal-pin-modal__case-item:hover {
  border-color: rgba(99, 102, 241, 0.35);
  background:   rgba(99, 102, 241, 0.06);
}
.signal-pin-modal__case-item:has(.signal-pin-modal__radio:checked) {
  border-color: rgba(99, 102, 241, 0.55);
  background:   rgba(99, 102, 241, 0.12);
}

.signal-pin-modal__radio {
  accent-color: #818cf8;
  flex-shrink:  0;
}

.signal-pin-modal__case-title {
  flex:      1;
  font-size: 0.78rem;
  color:     var(--text-secondary);
}

.signal-pin-modal__case-status {
  font-size:  0.6rem;
  color:      var(--text-ghost);
}

.signal-pin-modal__note-row {
  margin-bottom: var(--sp-3);
}

.signal-pin-modal__note-label {
  display:       block;
  font-size:     0.6rem;
  letter-spacing: 0.08em;
  color:         var(--text-dim);
  text-transform: uppercase;
  margin-bottom: var(--sp-1);
}

.signal-pin-modal__note-input {
  width:         100%;
  background:    var(--bg-void);
  border:        1px solid var(--border-dim);
  border-radius: var(--r-sm);
  color:         var(--text-secondary);
  font-family:   var(--font-mono);
  font-size:     0.72rem;
  padding:       var(--sp-2) var(--sp-3);
  outline:       none;
  box-sizing:    border-box;
  transition:    border-color var(--t-fast);
}
.signal-pin-modal__note-input:focus {
  border-color: rgba(99, 102, 241, 0.5);
}

.signal-pin-modal__footer {
  display: flex;
  gap:     var(--sp-2);
}

/* ── Map popup pin row ───────────────────────────────────────────────────────── */

.map-popup__pin-row {
  display:     flex;
  gap:         var(--sp-2);
  align-items: center;
}

.map-popup__case-select {
  flex:          1;
  background:    var(--bg-void);
  border:        1px solid var(--border-dim);
  border-radius: var(--r-sm);
  color:         var(--text-secondary);
  font-family:   var(--font-mono);
  font-size:     0.68rem;
  padding:       3px var(--sp-2);
  outline:       none;
  cursor:        pointer;
}
.map-popup__case-select:focus {
  border-color: rgba(99, 102, 241, 0.5);
}

/* ── Case detail page ────────────────────────────────────────────────────────── */

/* Case type badge in eyebrow */
.case-type-badge {
  display:        inline-block;
  padding:        1px 6px;
  border-radius:  3px;
  font-size:      0.58rem;
  letter-spacing: 0.1em;
  border:         1px solid rgba(255,255,255,0.12);
  color:          var(--text-dim);
  background:     rgba(255,255,255,0.04);
  margin-left:    var(--sp-1);
  vertical-align: middle;
}
.case-type-badge--criminal     { color:#f87171; border-color:rgba(248,113,113,0.3); background:rgba(248,113,113,0.07); }
.case-type-badge--financial    { color:#34d399; border-color:rgba(52,211,153,0.3);  background:rgba(52,211,153,0.07);  }
.case-type-badge--geopolitical { color:#60a5fa; border-color:rgba(96,165,250,0.3);  background:rgba(96,165,250,0.07);  }
.case-type-badge--cyber        { color:#a78bfa; border-color:rgba(167,139,250,0.3); background:rgba(167,139,250,0.07); }
.case-type-badge--humanitarian { color:#fbbf24; border-color:rgba(251,191,36,0.3);  background:rgba(251,191,36,0.07);  }
.case-type-badge--infrastructure { color:#fb923c; border-color:rgba(251,146,60,0.3); background:rgba(251,146,60,0.07); }
.case-type-badge--other,
.case-type-badge--general      { color:var(--text-dim); }

/* Hypothesis card */
.case-hypothesis-card {
  position:      relative;
  margin:        var(--sp-4) 0;
  padding:       var(--sp-4) var(--sp-5);
  background:    rgba(99, 102, 241, 0.06);
  border:        1px solid rgba(99, 102, 241, 0.22);
  border-left:   3px solid #818cf8;
  border-radius: var(--r-md);
}
.case-hypothesis-card--plain {
  background: var(--bg-surface);
  border:     1px solid var(--border-dim);
  border-left: 3px solid var(--border-mid);
}

.case-hypothesis-card__eyebrow {
  font-size:      0.58rem;
  letter-spacing: 0.14em;
  color:          #818cf8;
  text-transform: uppercase;
  margin-bottom:  var(--sp-2);
}

.case-hypothesis-card__body {
  font-size:   0.88rem;
  line-height: 1.65;
  color:       var(--text-primary);
  margin:      0 0 var(--sp-2);
}
.case-hypothesis-card__body:last-child { margin-bottom: 0; }

.case-hypothesis-card__desc {
  font-size:   0.78rem;
  line-height: 1.6;
  color:       var(--text-dim);
  margin:      var(--sp-1) 0 0;
}

/* Stats bar */
.case-stats-bar {
  display:       flex;
  align-items:   center;
  gap:           var(--sp-4);
  padding:       var(--sp-3) 0;
  margin:        var(--sp-4) 0 0;
  border-top:    1px solid var(--border-dim);
  border-bottom: 1px solid var(--border-dim);
}

.case-stats-bar__item {
  display:     flex;
  align-items: baseline;
  gap:         var(--sp-2);
}
.case-stats-bar__item--signal { margin-left: var(--sp-2); }

.case-stats-bar__val {
  font-size:   1.4rem;
  font-weight: 600;
  color:       var(--text-primary);
  line-height: 1;
}
.case-stats-bar__val--signal { color: #818cf8; }

.case-stats-bar__label {
  font-size:      0.62rem;
  letter-spacing: 0.08em;
  color:          var(--text-dim);
}

.case-stats-bar__sep {
  width:      1px;
  height:     24px;
  background: var(--border-dim);
}

/* Tab nav */
.case-tab-nav {
  display:       flex;
  gap:           2px;
  margin:        var(--sp-5) 0 0;
  border-bottom: 1px solid var(--border-dim);
}

.case-tab-btn {
  display:        flex;
  align-items:    center;
  gap:            var(--sp-2);
  padding:        var(--sp-2) var(--sp-4);
  background:     transparent;
  border:         none;
  border-bottom:  2px solid transparent;
  color:          var(--text-dim);
  font-family:    var(--font-mono);
  font-size:      0.7rem;
  letter-spacing: 0.06em;
  cursor:         pointer;
  transition:     all var(--t-fast);
  margin-bottom:  -1px;
}
.case-tab-btn:hover {
  color: var(--text-secondary);
}
.case-tab-btn--active {
  color:        var(--text-primary);
  border-bottom-color: #818cf8;
}

.case-tab-count {
  background:    rgba(99,102,241,0.18);
  color:         #818cf8;
  font-size:     0.58rem;
  padding:       1px 5px;
  border-radius: 3px;
  min-width:     16px;
  text-align:    center;
}

/* Tab panels */
.case-tab-panel { display: none; }
.case-tab-panel--active { display: block; }

/* Edit form */
.case-edit-panel {
  margin:        var(--sp-4) 0;
  padding:       var(--sp-5);
  background:    var(--bg-surface);
  border:        1px solid var(--border-mid);
  border-radius: var(--r-md);
}
.case-edit-form {
  display:               grid;
  grid-template-columns: 1fr 1fr;
  gap:                   var(--sp-3) var(--sp-4);
}
.case-edit-row { display: flex; flex-direction: column; gap: var(--sp-1); }
.case-edit-row--full { grid-column: 1 / -1; }

.case-edit-label {
  font-size:      0.6rem;
  letter-spacing: 0.1em;
  color:          var(--text-dim);
  text-transform: uppercase;
}
.case-edit-label__hint {
  display:    block;
  font-size:  0.62rem;
  color:      var(--text-ghost);
  font-style: italic;
  letter-spacing: 0;
  margin-top: 2px;
  text-transform: none;
}

.case-edit-input,
.case-edit-select,
.case-edit-textarea {
  background:    var(--bg-void);
  border:        1px solid var(--border-dim);
  border-radius: var(--r-sm);
  color:         var(--text-secondary);
  font-family:   var(--font-mono);
  font-size:     0.78rem;
  padding:       var(--sp-2) var(--sp-3);
  outline:       none;
  transition:    border-color var(--t-fast);
  width:         100%;
  box-sizing:    border-box;
}
.case-edit-input:focus,
.case-edit-select:focus,
.case-edit-textarea:focus { border-color: rgba(99,102,241,0.5); }

.case-edit-textarea         { resize: vertical; line-height: 1.5; }
.case-edit-textarea--hypothesis {
  font-family:  var(--font-body, var(--font-sans));
  font-size:    0.82rem;
  color:        var(--text-primary);
}

.case-edit-footer {
  grid-column: 1 / -1;
  display:     flex;
  gap:         var(--sp-2);
  padding-top: var(--sp-2);
  border-top:  1px solid var(--border-dim);
}

/* Intelligence feed */
.case-intel-header {
  display:         flex;
  justify-content: space-between;
  align-items:     center;
  margin:          var(--sp-4) 0 var(--sp-3);
}

.case-intel-header__label {
  font-size:      0.6rem;
  letter-spacing: 0.12em;
  color:          var(--text-dim);
  text-transform: uppercase;
}

.case-intel-empty {
  display:         flex;
  flex-direction:  column;
  align-items:     center;
  justify-content: center;
  gap:             var(--sp-3);
  padding:         var(--sp-12) var(--sp-6);
  text-align:      center;
}
.case-intel-empty__icon {
  font-size: 2rem;
  color:     var(--text-ghost);
  opacity:   0.4;
}
.case-intel-empty__title {
  font-size: 0.75rem;
  color:     var(--text-dim);
}
.case-intel-empty__hint {
  font-size:   0.75rem;
  color:       var(--text-ghost);
  max-width:   400px;
  line-height: 1.6;
}
.case-intel-empty__hint a {
  color: var(--accent);
  text-decoration: none;
}
.case-intel-empty__hint a:hover { text-decoration: underline; }

/* Signal feed timeline list */
.case-signal-feed {
  list-style:   none;
  padding:      0;
  margin:       0;
}

.case-signal-item {
  display: flex;
  gap:     var(--sp-4);
}

.case-signal-item__timeline {
  display:        flex;
  flex-direction: column;
  align-items:    center;
  flex-shrink:    0;
  width:          20px;
  padding-top:    var(--sp-1);
}

.case-signal-item__node {
  width:         10px;
  height:        10px;
  border-radius: 50%;
  border:        2px solid var(--border-mid);
  background:    var(--bg-surface);
  flex-shrink:   0;
  z-index:       1;
}
.case-signal-item__node--gdelt    { border-color: #818cf8; background: rgba(99,102,241,0.2);  }
.case-signal-item__node--gdacs    { border-color: #34d399; background: rgba(16,185,129,0.2);  }
.case-signal-item__node--rss      { border-color: var(--accent); background: rgba(200,148,58,0.2); }
.case-signal-item__node--interpol { border-color: #fbbf24; background: rgba(245,158,11,0.2);  }
.case-signal-item__node--priority { border-color: #e05c5c; background: rgba(224,92,92,0.2);   }

.case-signal-item__line {
  flex:       1;
  width:      1px;
  background: var(--border-dim);
  min-height: var(--sp-4);
  margin:     2px 0;
}

.case-signal-item__card {
  flex:          1;
  margin-bottom: var(--sp-4);
  padding:       var(--sp-3) var(--sp-4);
  background:    var(--bg-surface);
  border:        1px solid var(--border-dim);
  border-radius: var(--r-md);
  transition:    border-color var(--t-fast);
}
.case-signal-item__card:hover {
  border-color: var(--border-mid);
}

.case-signal-item--priority .case-signal-item__card {
  border-left: 2px solid rgba(224,92,92,0.5);
  background:  rgba(224,92,92,0.025);
}

.case-signal-item__meta {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  flex-wrap:   wrap;
  margin-bottom: var(--sp-2);
}

.case-signal-item__ts,
.case-signal-item__coords {
  font-size: 0.62rem;
  color:     var(--text-ghost);
}

.case-signal-item__title {
  font-size:     0.84rem;
  color:         var(--text-primary);
  margin:        0 0 var(--sp-1);
  font-weight:   500;
  line-height:   1.4;
}

.case-signal-item__content {
  font-size:   0.76rem;
  color:       var(--text-dim);
  line-height: 1.6;
  margin:      0 0 var(--sp-2);
}

.case-signal-item__pin-note {
  font-size:     0.72rem;
  color:         var(--text-secondary);
  font-style:    italic;
  padding:       var(--sp-2) var(--sp-3);
  border-left:   2px solid rgba(99,102,241,0.4);
  margin-bottom: var(--sp-2);
  background:    rgba(99,102,241,0.04);
  border-radius: 0 var(--r-sm) var(--r-sm) 0;
}

.case-signal-item__pin-note-label {
  font-style:  normal;
  color:       var(--text-ghost);
  font-size:   0.6rem;
}

.case-signal-item__footer {
  display:         flex;
  justify-content: space-between;
  align-items:     center;
  margin-top:      var(--sp-2);
  padding-top:     var(--sp-2);
  border-top:      1px solid var(--border-dim);
}

.case-signal-item__pinned-at {
  font-size: 0.6rem;
  color:     var(--text-ghost);
}

.case-signal-item__actions { display: flex; gap: var(--sp-1); }

.btn--unlink {
  color:        var(--text-dim);
  border-color: var(--border-dim);
  font-size:    0.62rem;
  padding:      2px 7px;
}
.btn--unlink:hover {
  color:        #f87171;
  border-color: rgba(248,113,113,0.4);
  background:   rgba(248,113,113,0.06);
}

/* ── Phase 16: Intel Feed section layout (case_detail.html) ───────────────── */

.intel-feed-section {
  margin-top:    var(--sp-6);
  padding-top:   var(--sp-5);
  border-top:    1px solid var(--border-dim);
}

.intel-feed-header {
  display:         flex;
  justify-content: space-between;
  align-items:     flex-start;
  gap:             var(--sp-4);
  margin-bottom:   var(--sp-4);
  flex-wrap:       wrap;
}

.intel-feed-header__left {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
}

.intel-feed-header__icon {
  font-size: 1rem;
  color:     #818cf8;
}

.intel-feed-header__title {
  font-size:   1rem;
  font-weight: 600;
  color:       var(--text-primary);
  margin:      0;
}

.intel-feed-header__count {
  font-size:   0.65rem;
  color:       #818cf8;
  background:  rgba(99,102,241,0.15);
  padding:     1px 7px;
  border-radius: 3px;
}

.intel-feed-header__right {
  display:     flex;
  align-items: flex-start;
  gap:         var(--sp-3);
}

.intel-feed-hypothesis {
  max-width:   420px;
  padding:     var(--sp-3) var(--sp-4);
  background:  rgba(99,102,241,0.06);
  border:      1px solid rgba(99,102,241,0.2);
  border-left: 3px solid #818cf8;
  border-radius: var(--r-sm);
}

.intel-feed-hypothesis__eyebrow {
  display:        block;
  font-size:      0.55rem;
  letter-spacing: 0.12em;
  color:          #818cf8;
  text-transform: uppercase;
  margin-bottom:  var(--sp-1);
}

.intel-feed-hypothesis__body {
  font-size:   0.76rem;
  color:       var(--text-secondary);
  line-height: 1.55;
  margin:      0;
}

/* Signal stats in analytics bar */
.analytics-pin-stat--signal { margin-left: var(--sp-2); }
.analytics-pin-stat__val--signal { color: #818cf8; }

/* ============================================================================
   Phase 19 — Artifact-First Architecture: Gallery + Processing Status
   ============================================================================ */

/* ── Gallery filter sidebar links ────────────────────────────────────────── */

.gallery-filter-link {
  display:         flex;
  align-items:     center;
  justify-content: space-between;
  padding:         var(--sp-2) var(--sp-3);
  border-radius:   var(--r-sm);
  font-size:       0.72rem;
  font-family:     var(--font-mono);
  color:           var(--text-secondary);
  text-decoration: none;
  transition:      background var(--t-fast), color var(--t-fast);
  gap:             var(--sp-2);
}
.gallery-filter-link:hover {
  background: var(--bg-hover);
  color:      var(--text-primary);
}
.gallery-filter-link--active {
  background: var(--bg-elevated);
  color:      var(--accent);
  border:     1px solid var(--border-dim);
}

.gallery-filter-count {
  font-size:  0.62rem;
  color:      var(--text-ghost);
  font-family: var(--font-mono);
  flex-shrink: 0;
}

/* ── Artifact processing status badge ────────────────────────────────────── */

.artifact-status-badge {
  display:        inline-block;
  padding:        1px 6px;
  border-radius:  var(--r-sm);
  font-size:      0.58rem;
  font-family:    var(--font-mono);
  letter-spacing: 0.07em;
  text-transform: uppercase;
  border:         1px solid transparent;
  white-space:    nowrap;
}

.artifact-status-badge--pending    {
  color: var(--text-dim);
  border-color: var(--border-dim);
  background: transparent;
}
.artifact-status-badge--processing {
  color: #818cf8;
  border-color: rgba(129,140,248,0.30);
  background: rgba(129,140,248,0.07);
  animation: artifact-processing-pulse 1.5s ease-in-out infinite;
}
.artifact-status-badge--done       {
  color: #34d399;
  border-color: rgba(52,211,153,0.30);
  background: rgba(52,211,153,0.07);
}
.artifact-status-badge--failed     {
  color: #e05c5c;
  border-color: rgba(224,92,92,0.30);
  background: rgba(224,92,92,0.07);
}
.artifact-status-badge--skipped    {
  color: var(--text-ghost);
  border-color: var(--border-subtle);
  background: transparent;
}

@keyframes artifact-processing-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.45; }
}

/* ── Gallery card extensions (on top of existing .artifact-card) ─────────── */

.gallery-card__thumb {
  width:      100%;
  height:     140px;
  overflow:   hidden;
  background: var(--bg-elevated);
  display:    flex;
  align-items: center;
  justify-content: center;
}
.gallery-card__thumb img {
  width:      100%;
  height:     100%;
  object-fit: cover;
  display:    block;
  transition: transform 0.4s ease;
}
.artifact-card:hover .gallery-card__thumb img {
  transform: scale(1.03);
}
.gallery-card__thumb-placeholder {
  font-size:  2rem;
  opacity:    0.25;
  user-select: none;
}

.gallery-card__tags {
  display:    flex;
  flex-wrap:  wrap;
  gap:        var(--sp-1);
  margin-top: var(--sp-1);
}

.gallery-tag {
  padding:        1px 6px;
  border-radius:  var(--r-sm);
  font-size:      0.6rem;
  font-family:    var(--font-mono);
  color:          var(--text-dim);
  background:     var(--bg-elevated);
  border:         1px solid var(--border-subtle);
  white-space:    nowrap;
}

.gallery-card__text-indicator {
  font-size:  0.6rem;
  color:      var(--text-dim);
  margin-top: var(--sp-1);
}
.gallery-card__text-indicator--pending {
  color: var(--text-ghost);
  font-style: italic;
}

.gallery-card__footer {
  display:       flex;
  align-items:   center;
  gap:           var(--sp-2);
  padding:       var(--sp-2) var(--sp-4) var(--sp-3);
  border-top:    1px solid var(--border-subtle);
  margin-top:    auto;
}

/* ── Signal breadcrumb in Signal Monitor rows ────────────────────────────── */

.signal-artifact-crumb {
  display:        inline-flex;
  align-items:    center;
  gap:            4px;
  font-size:      0.6rem;
  font-family:    var(--font-mono);
  color:          var(--text-dim);
  padding:        1px 5px;
  border-radius:  var(--r-sm);
  background:     var(--bg-elevated);
  border:         1px solid var(--border-subtle);
  text-decoration: none;
  transition:     color var(--t-fast), border-color var(--t-fast);
  white-space:    nowrap;
  max-width:      160px;
  overflow:       hidden;
  text-overflow:  ellipsis;
}
.signal-artifact-crumb:hover {
  color:         var(--accent);
  border-color:  var(--accent-muted);
}
.signal-artifact-crumb__icon {
  flex-shrink: 0;
  opacity: 0.6;
}


/* ============================================================================
   Phase 17 — System Pulse Graph
   ============================================================================ */

.pulse-section {
  margin: var(--sp-8) 0 var(--sp-6);
}
.pulse-section__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--sp-4);
  margin-bottom: var(--sp-4);
  flex-wrap: wrap;
}
.pulse-section__eyebrow {
  font-size: 0.6rem;
  letter-spacing: 0.14em;
  color: var(--text-ghost);
  text-transform: uppercase;
  margin-bottom: var(--sp-1);
}
.pulse-section__title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
  margin: 0;
  display: flex;
  align-items: center;
  gap: var(--sp-2);
}
.pulse-section__title-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--accent);
  display: inline-block;
  animation: pulse-title-dot 2.4s ease-in-out infinite;
}
@keyframes pulse-title-dot {
  0%, 100% { opacity: 1;   transform: scale(1);    }
  50%       { opacity: 0.4; transform: scale(0.65); }
}
.pulse-section__meta {
  font-size: 0.68rem;
  color: var(--text-dim);
  font-family: var(--font-mono);
}

.pulse-card {
  position: relative;
  background: var(--bg-surface);
  border: 1px solid var(--border-dim);
  border-radius: var(--r-lg);
  padding: var(--sp-4) var(--sp-5) var(--sp-3);
  overflow: hidden;
}
.pulse-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom,
    transparent 0%, var(--accent) 40%,
    var(--accent) 60%, transparent 100%);
  opacity: 0.5;
}
.pulse-canvas-wrap {
  position: relative;
  height: 160px;
}
.pulse-canvas-wrap canvas {
  display: block;
  width: 100% !important;
  height: 100% !important;
}

.pulse-stats {
  display: flex;
  align-items: center;
  gap: var(--sp-5);
  margin-top: var(--sp-3);
  padding-top: var(--sp-3);
  border-top: 1px solid var(--border-dim);
  flex-wrap: wrap;
}
.pulse-stat {
  display: flex;
  align-items: baseline;
  gap: var(--sp-2);
}
.pulse-stat__val {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--text-primary);
  font-family: var(--font-mono);
  line-height: 1;
}
.pulse-stat__val--priority { color: #e05c5c; }
.pulse-stat__val--usgs     { color: #fb8c6a; }
.pulse-stat__val--gdelt    { color: #818cf8; }
.pulse-stat__val--gdacs    { color: #34d399; }
.pulse-stat__label {
  font-size: 0.6rem;
  letter-spacing: 0.08em;
  color: var(--text-dim);
  text-transform: uppercase;
}
.pulse-stat__sep {
  width: 1px;
  height: 20px;
  background: var(--border-dim);
  flex-shrink: 0;
}

.pulse-source-pills {
  display: flex;
  align-items: center;
  gap: var(--sp-1);
}
.pulse-pill {
  padding: 2px 8px;
  border-radius: 3px;
  border: 1px solid rgba(255,255,255,0.10);
  background: transparent;
  color: var(--text-dim);
  font-size: 0.6rem;
  font-family: var(--font-mono);
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: all var(--t-fast);
}
.pulse-pill:hover { color: var(--text-secondary); border-color: rgba(255,255,255,0.2); }
.pulse-pill--active           { color: var(--text-primary); border-color: rgba(255,255,255,0.25); background: rgba(255,255,255,0.05); }
.pulse-pill--usgs.pulse-pill--active  { color: #fb8c6a; background: rgba(251,100,50,0.12);  border-color: rgba(251,100,50,0.4);  }
.pulse-pill--gdelt.pulse-pill--active { color: #818cf8; background: rgba(99,102,241,0.12); border-color: rgba(99,102,241,0.4); }
.pulse-pill--gdacs.pulse-pill--active { color: #34d399; background: rgba(16,185,129,0.12); border-color: rgba(16,185,129,0.4); }
.pulse-pill--rss.pulse-pill--active   { color: var(--accent); background: rgba(200,148,58,0.12); border-color: rgba(200,148,58,0.4); }
.pulse-pill--firms.pulse-pill--active { color: #f87171; background: rgba(239,68,68,0.12); border-color: rgba(239,68,68,0.40); }

.pulse-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 160px;
  gap: var(--sp-2);
  color: var(--text-ghost);
}
.pulse-empty__icon  { font-size: 1.6rem; opacity: 0.3; }
.pulse-empty__label { font-size: 0.7rem; font-family: var(--font-mono); letter-spacing: 0.08em; }


/* ============================================================================
   Phase 18 — Spatial Density, NER & Confidence / Source Badges
   ============================================================================ */

/* USGS — seismic orange */
.source-badge--usgs {
  background: rgba(251, 100, 50, 0.10);
  color:       #fb8c6a;
  border:      1px solid rgba(251, 100, 50, 0.30);
}
.source-badge--usgs:hover { background: rgba(251, 100, 50, 0.18); }

/* FIRMS — fire red */
.source-badge--firms {
  background: rgba(239, 68, 68, 0.10);
  color:       #f87171;
  border:      1px solid rgba(239, 68, 68, 0.30);
}
.source-badge--firms:hover { background: rgba(239, 68, 68, 0.18); }

/* Confidence score bar */
.confidence-bar {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  vertical-align: middle;
}
.confidence-bar__track {
  width: 60px;
  height: 4px;
  background: var(--bg-elevated);
  border-radius: 2px;
  overflow: hidden;
}
.confidence-bar__fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.4s ease;
}
.confidence-bar__fill--low  { background: #e05c5c; }
.confidence-bar__fill--mid  { background: var(--accent); }
.confidence-bar__fill--high { background: #34d399; }
.confidence-bar__val {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-dim);
  letter-spacing: 0.04em;
  white-space: nowrap;
}

/* Entity chips */
.entity-chip {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 7px;
  border-radius: 3px;
  font-size: 0.62rem;
  font-family: var(--font-mono);
  letter-spacing: 0.04em;
  white-space: nowrap;
}
.entity-chip--person { background: rgba(129,140,248,0.10); color: #818cf8; border: 1px solid rgba(129,140,248,0.25); }
.entity-chip--org    { background: rgba(200,148,58,0.10);  color: var(--accent); border: 1px solid rgba(200,148,58,0.25); }
.entity-chip--gpe    { background: rgba(52,211,153,0.10);  color: #34d399; border: 1px solid rgba(52,211,153,0.25); }


/* ============================================================================
   Phase 20 — Map Optimisation: Supercluster bubble markers
   ============================================================================
   .forge-sc-cluster is the divIcon className for Supercluster aggregate
   bubbles.  Needs the same "no background bleed" reset as .forge-cluster,
   plus pointer cursor and a hover lift so it's clearly clickable.
   The bubble itself is drawn as an inline SVG — no extra sizing needed here.
   ============================================================================ */

.forge-sc-cluster {
  background:    none   !important;
  border:        none   !important;
  cursor:        pointer;
  transition:    transform 120ms ease, filter 120ms ease;
}

.forge-sc-cluster:hover {
  transform: scale(1.12);
  filter:    brightness(1.25);
}

/* ============================================================================
   Phase 21 — Graph Intelligence Engine: Network Position Panel
   ============================================================================ */

/* ── Panel container ─────────────────────────────────────────────────────── */

.network-panel {
  background:    var(--bg-surface);
  border:        1px solid var(--border-dim);
  border-radius: var(--r-lg);
  overflow:      hidden;
  margin-top:    var(--sp-6);
}

.network-panel__header {
  display:         flex;
  align-items:     center;
  justify-content: space-between;
  padding:         var(--sp-3) var(--sp-5);
  background:      var(--bg-elevated);
  border-bottom:   1px solid var(--border-dim);
}

.network-panel__title {
  font-family:    var(--font-mono);
  font-size:      0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color:          var(--text-dim);
  display:        flex;
  align-items:    center;
  gap:            var(--sp-2);
}

.network-panel__body {
  padding:        var(--sp-5);
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-5);
}

/* ── Community badge ─────────────────────────────────────────────────────── */

.community-badge {
  display:        inline-flex;
  align-items:    center;
  padding:        2px 8px;
  border-radius:  var(--r-full, 999px);
  font-family:    var(--font-mono);
  font-size:      0.6rem;
  font-weight:    600;
  letter-spacing: 0.06em;
  border:         1px solid currentColor;
}

/* 8 community colours cycling through the FORGE palette */
.community-badge--0 { color: #818cf8; background: rgba(129,140,248,0.10); }
.community-badge--1 { color: #34d399; background: rgba( 52,211,153,0.10); }
.community-badge--2 { color: #c8943a; background: rgba(200,148, 58,0.10); }
.community-badge--3 { color: #e05c5c; background: rgba(224, 92, 92,0.10); }
.community-badge--4 { color: #a78bfa; background: rgba(167,139,250,0.10); }
.community-badge--5 { color: #38bdf8; background: rgba( 56,189,248,0.10); }
.community-badge--6 { color: #fb923c; background: rgba(251,146, 60,0.10); }
.community-badge--7 { color: #f472b6; background: rgba(244,114,182,0.10); }

/* ── Metric bars ─────────────────────────────────────────────────────────── */

.network-metrics-grid {
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-4);
}

.network-metric { display: flex; flex-direction: column; gap: var(--sp-1); }

.network-metric__header {
  display:         flex;
  align-items:     baseline;
  justify-content: space-between;
}

.network-metric__label {
  font-family:    var(--font-mono);
  font-size:      0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--text-dim);
}

.network-metric__value {
  font-size: 0.72rem;
  color:     var(--text-secondary);
}

.network-metric__bar-track {
  height:        4px;
  background:    var(--bg-elevated);
  border-radius: 2px;
  overflow:      hidden;
}

.network-metric__bar {
  height:        100%;
  border-radius: 2px;
  min-width:     2px;
  transition:    width 0.4s ease;
}

.network-metric__bar--pagerank    { background: #818cf8; }
.network-metric__bar--betweenness { background: #c8943a; }
.network-metric__bar--eigenvector { background: #34d399; }

.network-metric__desc {
  font-size:  0.62rem;
  color:      var(--text-ghost);
  line-height: 1.4;
}

/* ── Graph metadata line ─────────────────────────────────────────────────── */

.network-meta {
  padding-top:   var(--sp-2);
  border-top:    1px solid var(--border-subtle);
}

/* ── Rank list ───────────────────────────────────────────────────────────── */

.network-rank__heading {
  font-size:      0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--text-ghost);
  margin-bottom:  var(--sp-2);
}

.network-rank__list {
  list-style: none;
  padding:    0;
  margin:     0;
  display:    flex;
  flex-direction: column;
  gap:        2px;
}

.network-rank__item {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  padding:     var(--sp-1) var(--sp-2);
  border-radius: var(--r-sm);
  transition:  background 120ms;
}

.network-rank__item:hover { background: var(--bg-elevated); }

.network-rank__item--current {
  background:  rgba(200,148,58,0.08) !important;
  border-left: 2px solid var(--accent);
  padding-left: calc(var(--sp-2) - 2px);
}

.network-rank__link {
  display:     flex;
  align-items: baseline;
  gap:         var(--sp-2);
  flex:        1;
  min-width:   0;
  text-decoration: none;
}

.network-rank__name {
  font-size:     0.75rem;
  color:         var(--text-primary);
  white-space:   nowrap;
  overflow:      hidden;
  text-overflow: ellipsis;
}

.network-rank__type {
  font-size:  0.58rem;
  color:      var(--text-ghost);
  flex-shrink: 0;
}

.network-rank__score {
  font-size:   0.65rem;
  color:       var(--text-dim);
  flex-shrink: 0;
  margin-left: auto;
}

/* ── Empty / not-computed state ──────────────────────────────────────────── */

.network-empty {
  display:         flex;
  flex-direction:  column;
  align-items:     center;
  padding:         var(--sp-6) var(--sp-4);
  text-align:      center;
}

.network-empty__icon {
  font-size:    2rem;
  color:        var(--text-ghost);
  margin-bottom: var(--sp-3);
  opacity:      0.4;
}

.network-empty__text {
  font-size:  0.75rem;
  color:      var(--text-dim);
  max-width:  240px;
  line-height: 1.5;
}


/* ============================================================================
   Phase 20 — Forensic Artifact Intelligence Layer
   ============================================================================ */

.forensic-panel {
  background:    var(--bg-surface);
  border:        1px solid var(--border-dim);
  border-radius: var(--r-lg);
  overflow:      hidden;
  margin-top:    var(--sp-6);
}

.forensic-panel__header {
  display:         flex;
  align-items:     center;
  justify-content: space-between;
  padding:         var(--sp-3) var(--sp-5);
  background:      var(--bg-elevated);
  border-bottom:   1px solid var(--border-dim);
}

.forensic-panel__title {
  font-family:    var(--font-mono);
  font-size:      0.65rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color:          var(--text-dim);
  display:        flex;
  align-items:    center;
  gap:            var(--sp-2);
}

.forensic-panel__title-icon { color: var(--accent); opacity: 0.8; }

.forensic-panel__body {
  padding:        var(--sp-4) var(--sp-5);
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-4);
}

.forensic-hash { display: flex; align-items: baseline; gap: var(--sp-3); flex-wrap: wrap; }

.forensic-hash__label {
  font-family:    var(--font-mono);
  font-size:      0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--text-dim);
  width:          48px;
  flex-shrink:    0;
}

.forensic-hash__value {
  font-family:   var(--font-mono);
  font-size:     0.68rem;
  color:         var(--text-secondary);
  word-break:    break-all;
  background:    var(--bg-elevated);
  padding:       2px 6px;
  border-radius: var(--r-sm);
  border:        1px solid var(--border-subtle);
  flex:          1;
}

.forensic-grid {
  display:               grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap:                   var(--sp-3);
}

.forensic-field        { display: flex; flex-direction: column; gap: 2px; }

.forensic-field__label {
  font-family:    var(--font-mono);
  font-size:      0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--text-ghost);
}

.forensic-field__value { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-secondary); }

.forensic-gps-badge {
  display:       inline-flex;
  align-items:   center;
  gap:           var(--sp-2);
  padding:       var(--sp-2) var(--sp-3);
  background:    rgba(52,211,153,0.08);
  border:        1px solid rgba(52,211,153,0.25);
  border-radius: var(--r-md);
  font-family:   var(--font-mono);
  font-size:     0.68rem;
  color:         #34d399;
}

.forensic-gps-badge__icon { opacity: 0.7; }

.forensic-duplicate-alert {
  display:       flex;
  align-items:   flex-start;
  gap:           var(--sp-3);
  padding:       var(--sp-3) var(--sp-4);
  background:    rgba(224,92,92,0.07);
  border:        1px solid rgba(224,92,92,0.25);
  border-left:   3px solid #e05c5c;
  border-radius: var(--r-sm);
}

.forensic-duplicate-alert__icon   { color: #e05c5c; font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
.forensic-duplicate-alert__body   { flex: 1; }

.forensic-duplicate-alert__heading {
  font-family:    var(--font-mono);
  font-size:      0.65rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color:          #e05c5c;
  margin-bottom:  var(--sp-1);
}

.forensic-duplicate-alert__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
.forensic-duplicate-alert__list a       { font-size: 0.72rem; color: var(--text-secondary); }
.forensic-duplicate-alert__list a:hover { color: var(--accent); }

.forensic-integrity { display: flex; align-items: center; gap: var(--sp-2); font-family: var(--font-mono); font-size: 0.65rem; }

.forensic-integrity__dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

.forensic-integrity--verified .forensic-integrity__dot  { background: #34d399; }
.forensic-integrity--pending  .forensic-integrity__dot  { background: var(--accent); }
.forensic-integrity--unknown  .forensic-integrity__dot  { background: var(--text-ghost); }
.forensic-integrity--verified .forensic-integrity__label { color: #34d399; }
.forensic-integrity--pending  .forensic-integrity__label { color: var(--accent); }
.forensic-integrity--unknown  .forensic-integrity__label { color: var(--text-ghost); }

/* ============================================================================
   Phase 22 — Relationship Extraction: Named Relationship Panel
   ============================================================================ */

.rel-panel { background: var(--bg-surface); border: 1px solid var(--border-dim); border-radius: var(--r-lg); overflow: hidden; margin-top: var(--sp-6); }

.rel-panel__header { display: flex; align-items: center; justify-content: space-between; padding: var(--sp-3) var(--sp-5); background: var(--bg-elevated); border-bottom: 1px solid var(--border-dim); }

.rel-panel__title { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-dim); display: flex; align-items: center; gap: var(--sp-2); }

.rel-panel__body { padding: var(--sp-4) var(--sp-5); display: flex; flex-direction: column; gap: var(--sp-4); }

/* ── Relationship list ───────────────────────────────────────────────────── */

.rel-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--sp-2); }

.rel-item { display: flex; flex-direction: column; gap: var(--sp-1); padding: var(--sp-3) var(--sp-3); background: var(--bg-elevated); border-radius: var(--r-md); border: 1px solid var(--border-subtle); }

.rel-item__main { display: flex; align-items: center; gap: var(--sp-2); flex-wrap: wrap; font-size: 0.75rem; }

.rel-item__self  { color: var(--text-dim); font-style: italic; }
.rel-item__peer  { color: var(--accent); text-decoration: none; }
.rel-item__peer:hover { text-decoration: underline; }
.rel-item__arrow { color: var(--text-ghost); font-size: 0.7rem; }

.rel-item__type { font-family: var(--font-mono); font-size: 0.65rem; padding: 1px 6px; border-radius: var(--r-sm); font-weight: 600; }
.rel-item__type--out { background: rgba(200,148,58,0.12); color: #c8943a; border: 1px solid rgba(200,148,58,0.25); }
.rel-item__type--in  { background: rgba(129,140,248,0.12); color: #818cf8; border: 1px solid rgba(129,140,248,0.25); }

.rel-item__meta { display: flex; align-items: center; gap: var(--sp-3); flex-wrap: wrap; }

.rel-item__method { font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 1px 5px; border-radius: var(--r-sm); }
.rel-item__method--manual { background: rgba(200,148,58,0.08); color: #c8943a; }
.rel-item__method--spacy  { background: rgba(129,140,248,0.08); color: #818cf8; }
.rel-item__method--llm    { background: rgba(52,211,153,0.08);  color: #34d399; }

.rel-item__confidence { font-size: 0.6rem; color: var(--text-dim); }
.rel-item__desc       { font-size: 0.62rem; color: var(--text-ghost); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.rel-item__delete { background: none; border: none; cursor: pointer; color: var(--text-ghost); font-size: 0.6rem; padding: 2px 4px; border-radius: var(--r-sm); margin-left: auto; flex-shrink: 0; }
.rel-item__delete:hover { color: #e05c5c; background: rgba(224,92,92,0.08); }

.rel-empty { padding: var(--sp-3) 0; }

/* ── Add relationship form ───────────────────────────────────────────────── */

.rel-add { border-top: 1px solid var(--border-dim); padding-top: var(--sp-4); }

.rel-add__heading { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-ghost); margin-bottom: var(--sp-3); }

.rel-add__form { display: flex; flex-direction: column; gap: var(--sp-3); }

.rel-add__row { display: flex; gap: var(--sp-3); flex-wrap: wrap; }

.rel-add__row--secondary { align-items: flex-end; }

.rel-add__field { display: flex; flex-direction: column; gap: var(--sp-1); flex: 1; min-width: 140px; }

.rel-add__field--fixed { flex: 0 0 auto; }

.rel-add__label { font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-ghost); }

.rel-add__subject { font-size: 0.75rem; color: var(--text-dim); padding: var(--sp-2) var(--sp-3); background: var(--bg-elevated); border-radius: var(--r-sm); border: 1px solid var(--border-subtle); }

.rel-add__input,
.rel-add__select {
  background:    var(--bg-elevated);
  border:        1px solid var(--border-mid);
  border-radius: var(--r-sm);
  color:         var(--text-primary);
  font-family:   var(--font-mono);
  font-size:     0.72rem;
  padding:       var(--sp-2) var(--sp-3);
  width:         100%;
  outline:       none;
  transition:    border-color 120ms;
}

.rel-add__input:focus,
.rel-add__select:focus { border-color: var(--accent); }

.rel-add__range { width: 100%; accent-color: var(--accent); cursor: pointer; }

.rel-add__actions { display: flex; align-items: center; gap: var(--sp-3); }

.rel-add__status { font-size: 0.65rem; color: var(--text-dim); }

/* ============================================================================
   Phase 23 — Correlation Engine: Correlated Incidents Panel
   ============================================================================ */

/* ── Section on dashboard ────────────────────────────────────────────────── */

.corr-list {
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-3);
  margin-top:     var(--sp-3);
}

.corr-item {
  display:        flex;
  align-items:    center;
  gap:            var(--sp-4);
  padding:        var(--sp-4) var(--sp-5);
  background:     var(--bg-surface);
  border:         1px solid var(--border-dim);
  border-radius:  var(--r-lg);
  border-left:    3px solid var(--accent);
  transition:     border-color 150ms, background 150ms;
}

.corr-item:hover {
  background:   var(--bg-elevated);
  border-color: var(--border-mid);
  border-left-color: #e05c5c;
}

/* ── Score ring (left column) ────────────────────────────────────────────── */

.corr-item__score-col {
  display:        flex;
  flex-direction: column;
  align-items:    center;
  gap:            var(--sp-1);
  flex-shrink:    0;
  width:          52px;
}

.corr-item__score-ring {
  position:     relative;
  width:        44px;
  height:       44px;
  border-radius:50%;
  background:   conic-gradient(
    #c8943a calc(var(--score, 0) * 1%),
    var(--bg-elevated) 0%
  );
  display:      flex;
  align-items:  center;
  justify-content: center;
}

/* Inner circle cutout */
.corr-item__score-ring::before {
  content:       '';
  position:      absolute;
  inset:         5px;
  border-radius: 50%;
  background:    var(--bg-surface);
}

.corr-item__score-val {
  position:   relative;
  font-size:  0.62rem;
  font-weight:700;
  color:      var(--accent);
  z-index:    1;
}

.corr-item__score-label {
  font-size:      0.52rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color:          var(--text-ghost);
}

/* ── Signal pair body ────────────────────────────────────────────────────── */

.corr-item__body {
  flex:           1;
  min-width:      0;
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-2);
}

.corr-item__signals {
  display:        flex;
  flex-direction: column;
  gap:            3px;
}

.corr-item__signal {
  display:     flex;
  align-items: baseline;
  gap:         var(--sp-2);
  min-width:   0;
}

.corr-item__src {
  font-family:    var(--font-mono);
  font-size:      0.58rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding:        1px 5px;
  border-radius:  var(--r-sm);
  flex-shrink:    0;
}

/* Source colour coding — reuse signal source palette */
.corr-item__src--usgs  { background: rgba(59,130,246,0.12); color: #60a5fa; }
.corr-item__src--firms { background: rgba(239,68,68,0.12);  color: #f87171; }
.corr-item__src--gdelt { background: rgba(168,85,247,0.12); color: #c084fc; }
.corr-item__src--GDACS { background: rgba(245,158,11,0.12); color: #fbbf24; }

.corr-item__title {
  font-size:     0.78rem;
  color:         var(--text-secondary);
  white-space:   nowrap;
  overflow:      hidden;
  text-overflow: ellipsis;
}

.corr-item__connector {
  font-size:  0.7rem;
  color:      var(--text-ghost);
  padding-left: var(--sp-1);
}

.corr-item__meta {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  flex-wrap:   wrap;
}

.corr-item__meta-val {
  font-size: 0.65rem;
  color:     var(--text-dim);
}

.corr-item__meta-sep {
  color:     var(--text-ghost);
  font-size: 0.6rem;
}

/* ── Map link (right) ────────────────────────────────────────────────────── */

.corr-item__map-link {
  flex-shrink:  0;
  font-size:    1.1rem;
  color:        var(--text-ghost);
  text-decoration: none;
  padding:      var(--sp-2);
  border-radius:var(--r-md);
  transition:   color 120ms, background 120ms;
}

.corr-item__map-link:hover {
  color:      var(--accent);
  background: var(--bg-elevated);
}

/* ── Leaflet tooltip for correlation polylines ───────────────────────────── */

.map-corr-tip-wrap .leaflet-tooltip {
  background:    var(--bg-elevated, #0c1219) !important;
  border:        1px solid rgba(200,148,58,0.4) !important;
  border-radius: 6px !important;
  box-shadow:    0 4px 16px rgba(0,0,0,0.6) !important;
  padding:       6px 10px !important;
  color:         #cfdce8 !important;
}

.map-corr-tooltip {
  font-family: 'IBM Plex Mono', monospace;
  min-width:   180px;
}

/* ============================================================================
   Phase 24 — The Centrality Protocol: Intelligence Leads Panel
   ============================================================================ */

.leads-list {
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-2);
  margin-top:     var(--sp-3);
}

.lead-item {
  display:         flex;
  align-items:     center;
  gap:             var(--sp-4);
  padding:         var(--sp-4) var(--sp-5);
  background:      var(--bg-surface);
  border:          1px solid var(--border-dim);
  border-radius:   var(--r-lg);
  text-decoration: none;
  color:           inherit;
  transition:      background 150ms, border-color 150ms, transform 120ms;
}

.lead-item:hover {
  background:    var(--bg-elevated);
  border-color:  var(--border-mid);
  transform:     translateX(3px);
}

/* ── Rank number ─────────────────────────────────────────────────────────── */

.lead-item__rank {
  font-size:   1.1rem;
  font-weight: 700;
  color:       var(--text-ghost);
  width:       28px;
  text-align:  right;
  flex-shrink: 0;
}

.lead-item:nth-child(1) .lead-item__rank { color: #c8943a; }
.lead-item:nth-child(2) .lead-item__rank { color: var(--text-dim); }
.lead-item:nth-child(3) .lead-item__rank { color: #8a6420; }

/* ── Body ────────────────────────────────────────────────────────────────── */

.lead-item__body {
  flex:           1;
  min-width:      0;
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-2);
}

.lead-item__top {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  flex-wrap:   wrap;
}

.lead-item__name {
  font-size:   0.88rem;
  font-weight: 600;
  color:       var(--text-primary);
  white-space: nowrap;
  overflow:    hidden;
  text-overflow: ellipsis;
}

.lead-item__type {
  font-size:      0.6rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color:          var(--text-ghost);
  flex-shrink:    0;
}

/* ── Heat bar ────────────────────────────────────────────────────────────── */

.lead-item__heat-wrap {
  display:     flex;
  align-items: center;
  gap:         var(--sp-3);
}

.lead-item__heat-track {
  flex:          1;
  height:        5px;
  background:    var(--bg-elevated);
  border-radius: 3px;
  overflow:      hidden;
}

.lead-item__heat-fill {
  height:        100%;
  border-radius: 3px;
  min-width:     3px;
  transition:    width 0.5s ease;
}

.lead-item__score {
  font-size:   0.68rem;
  color:       var(--accent);
  flex-shrink: 0;
  font-weight: 600;
}

/* ── Sub metrics ─────────────────────────────────────────────────────────── */

.lead-item__sub {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
}

.lead-item__sub-val {
  font-size: 0.62rem;
  color:     var(--text-ghost);
}

.lead-item__sub-sep {
  color:     var(--text-ghost);
  font-size: 0.55rem;
}

/* ── Arrow ───────────────────────────────────────────────────────────────── */

.lead-item__arrow {
  color:       var(--text-ghost);
  font-size:   0.8rem;
  flex-shrink: 0;
  transition:  color 150ms;
}

.lead-item:hover .lead-item__arrow { color: var(--accent); }

/* ============================================================================
   Phase 25 — SENTINEL: Alert Bell, Incident Panel, Sidebar Badge
   ============================================================================ */

/* ── Sentinel bell (topbar) — sits next to the signal priority bell ──────── */

.topbar__sentinel-bell {
  position:   relative;
  display:    inline-flex;
  align-items: center;
  justify-content: center;
  width:      36px;
  height:     36px;
  border-radius: var(--r-md);
  color:      var(--text-ghost);
  text-decoration: none;
  transition: color 150ms, background 150ms;
}

.topbar__sentinel-bell:hover {
  color:       #e05c5c;
  background:  rgba(224,92,92,0.08);
}

.topbar__sentinel-bell--active {
  color: #e05c5c;
  animation: sentinel-pulse 2s ease-in-out infinite;
}

@keyframes sentinel-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.55; }
}

.topbar__sentinel-dot {
  position:      absolute;
  top:           4px;
  right:         4px;
  min-width:     16px;
  height:        16px;
  border-radius: 8px;
  background:    #e05c5c;
  color:         #fff;
  font-family:   var(--font-mono);
  font-size:     0.55rem;
  font-weight:   700;
  display:       flex;
  align-items:   center;
  justify-content: center;
  padding:       0 3px;
  border:        2px solid var(--bg-topbar, #080d12);
}

/* ── Sidebar Sentinel badge ─────────────────────────────────────────────── */

.nav-sentinel-badge {
  margin-left:   auto;
  background:    rgba(224,92,92,0.18);
  color:         #e05c5c;
  font-family:   var(--font-mono);
  font-size:     0.6rem;
  font-weight:   700;
  padding:       1px 6px;
  border-radius: 999px;
  border:        1px solid rgba(224,92,92,0.3);
}

.sentinel-nav-active {
  color: #e05c5c !important;
}

/* ── Sentinel alert list ────────────────────────────────────────────────── */

.sentinel-list {
  display:        flex;
  flex-direction: column;
  gap:            var(--sp-4);
  margin-top:     var(--sp-3);
}

/* ── Sentinel card ───────────────────────────────────────────────────────── */

.sentinel-card {
  background:    var(--bg-surface);
  border:        1px solid var(--border-dim);
  border-left:   3px solid #e05c5c;
  border-radius: var(--r-lg);
  overflow:      hidden;
}

.sentinel-card--cluster_spike      { border-left-color: #f59e0b; }
.sentinel-card--actor_match        { border-left-color: #818cf8; }
.sentinel-card--correlation_escalation { border-left-color: #e05c5c; }

/* ── Card header ─────────────────────────────────────────────────────────── */

.sentinel-card__header {
  padding:         var(--sp-3) var(--sp-5);
  background:      var(--bg-elevated);
  border-bottom:   1px solid var(--border-dim);
  display:         flex;
  flex-direction:  column;
  gap:             var(--sp-2);
}

.sentinel-card__type-row {
  display:     flex;
  align-items: center;
  gap:         var(--sp-3);
  flex-wrap:   wrap;
}

.sentinel-card__type-badge {
  font-family:    var(--font-mono);
  font-size:      0.65rem;
  font-weight:    700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding:        2px 8px;
  border-radius:  var(--r-sm);
  flex-shrink:    0;
}

.sentinel-card--correlation_escalation .sentinel-card__type-badge {
  background: rgba(224,92,92,0.12);
  color:      #e05c5c;
  border:     1px solid rgba(224,92,92,0.3);
}
.sentinel-card--cluster_spike .sentinel-card__type-badge {
  background: rgba(245,158,11,0.12);
  color:      #f59e0b;
  border:     1px solid rgba(245,158,11,0.3);
}
.sentinel-card--actor_match .sentinel-card__type-badge {
  background: rgba(129,140,248,0.12);
  color:      #818cf8;
  border:     1px solid rgba(129,140,248,0.3);
}

.sentinel-card__disclaimer {
  font-size:      0.58rem;
  letter-spacing: 0.1em;
  color:          var(--text-ghost);
  text-transform: uppercase;
}

.sentinel-card__meta-row {
  display:     flex;
  align-items: center;
  gap:         var(--sp-4);
  flex-wrap:   wrap;
}

/* ── Confidence bar ─────────────────────────────────────────────────────── */

.sentinel-card__conf-wrap {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  flex:        1;
  min-width:   160px;
}

.sentinel-card__conf-track {
  flex:          1;
  height:        4px;
  background:    var(--bg-surface);
  border-radius: 2px;
  overflow:      hidden;
}

.sentinel-card__conf-fill {
  height:           100%;
  border-radius:    2px;
  background:       linear-gradient(90deg, #818cf8, #c8943a, #e05c5c);
  transition:       width 0.4s ease;
}

.sentinel-card__conf-val {
  font-size:   0.62rem;
  color:       var(--text-secondary);
  flex-shrink: 0;
}

.sentinel-card__signals,
.sentinel-card__time {
  font-size:   0.62rem;
  color:       var(--text-ghost);
  flex-shrink: 0;
}

/* ── Card body ───────────────────────────────────────────────────────────── */

.sentinel-card__body {
  padding: var(--sp-4) var(--sp-5);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.sentinel-card__summary {
  font-size:   0.78rem;
  color:       var(--text-secondary);
  line-height: 1.6;
  margin:      0;
}

.sentinel-card__coords {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  margin-top:  var(--sp-1);
}

/* ── Card actions ────────────────────────────────────────────────────────── */

.sentinel-card__actions {
  display:      flex;
  align-items:  center;
  gap:          var(--sp-3);
  padding:      var(--sp-3) var(--sp-5);
  background:   var(--bg-elevated);
  border-top:   1px solid var(--border-dim);
  flex-wrap:    wrap;
}

/* ============================================================================
   Phase 26 — Anomaly Engine: statistical_anomaly alert variant
   ============================================================================ */

/* Left-border colour for statistical anomaly cards in Sentinel panel */
.sentinel-card--statistical_anomaly {
  border-left-color: #34d399;   /* emerald — distinct from red/amber/indigo */
}

.sentinel-card--statistical_anomaly .sentinel-card__type-badge {
  background: rgba(52,211,153,0.12);
  color:      #34d399;
  border:     1px solid rgba(52,211,153,0.3);
}

/* ============================================================================
   Phase 27 — Signal Stream Engine: Stream Badges + Stream Summary Cards
   ============================================================================ */

/* ── Stream badge — inline tag on signal rows ────────────────────────────── */

.stream-badge {
  display:        inline-flex;
  align-items:    center;
  font-family:    var(--font-mono);
  font-size:      0.58rem;
  font-weight:    700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding:        2px 7px;
  border-radius:  var(--r-sm);
  flex-shrink:    0;
  border:         1px solid currentColor;
}

.stream-badge--GLOBAL        { color: var(--text-ghost);  background: rgba(255,255,255,0.04); }
.stream-badge--CRIME_INTEL   { color: #e05c5c;            background: rgba(224,92,92,0.10);   }
.stream-badge--INFRASTRUCTURE{ color: #f59e0b;            background: rgba(245,158,11,0.10);  }
.stream-badge--PRIORITY      { color: #818cf8;            background: rgba(129,140,248,0.10); }

/* ── Stream filter pills — signals monitor header ────────────────────────── */

.stream-pills {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  flex-wrap:   wrap;
}

.stream-pill {
  display:         inline-flex;
  align-items:     center;
  gap:             var(--sp-1);
  font-family:     var(--font-mono);
  font-size:       0.62rem;
  font-weight:     600;
  letter-spacing:  0.06em;
  text-transform:  uppercase;
  padding:         var(--sp-1) var(--sp-3);
  border-radius:   999px;
  border:          1px solid var(--border-mid);
  color:           var(--text-dim);
  background:      transparent;
  text-decoration: none;
  cursor:          pointer;
  transition:      background 120ms, color 120ms, border-color 120ms;
}

.stream-pill:hover,
.stream-pill--active {
  background:   var(--bg-elevated);
  color:        var(--text-primary);
  border-color: var(--border-mid);
}

.stream-pill--active-CRIME_INTEL    { color: #e05c5c; border-color: rgba(224,92,92,0.5);    background: rgba(224,92,92,0.08);    }
.stream-pill--active-INFRASTRUCTURE { color: #f59e0b; border-color: rgba(245,158,11,0.5);   background: rgba(245,158,11,0.08);   }
.stream-pill--active-PRIORITY       { color: #818cf8; border-color: rgba(129,140,248,0.5);  background: rgba(129,140,248,0.08);  }
.stream-pill--active-GLOBAL         { color: var(--text-secondary); border-color: var(--border-mid); }

.stream-pill__count {
  font-size:    0.55rem;
  opacity:      0.7;
  margin-left:  2px;
}

/* ── Stream summary cards — dashboard widget ─────────────────────────────── */

.stream-grid {
  display:               grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap:                   var(--sp-3);
  margin-top:            var(--sp-3);
}

.stream-card {
  display:        flex;
  flex-direction: column;
  align-items:    flex-start;
  gap:            var(--sp-1);
  padding:        var(--sp-4) var(--sp-5);
  background:     var(--bg-surface);
  border:         1px solid var(--border-dim);
  border-radius:  var(--r-lg);
  border-top:     3px solid var(--border-dim);
  transition:     background 150ms, border-color 150ms, transform 120ms;
}

.stream-card:hover {
  background:  var(--bg-elevated);
  transform:   translateY(-2px);
}

.stream-card--CRIME_INTEL    { border-top-color: #e05c5c; }
.stream-card--INFRASTRUCTURE { border-top-color: #f59e0b; }
.stream-card--PRIORITY       { border-top-color: #818cf8; }
.stream-card--GLOBAL         { border-top-color: var(--text-ghost); }

.stream-card__name {
  font-size:      0.58rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color:          var(--text-ghost);
}

.stream-card--CRIME_INTEL    .stream-card__name { color: #e05c5c; }
.stream-card--INFRASTRUCTURE .stream-card__name { color: #f59e0b; }
.stream-card--PRIORITY       .stream-card__name { color: #818cf8; }

.stream-card__count {
  font-size:   1.8rem;
  font-weight: 700;
  color:       var(--text-primary);
  line-height: 1;
}

.stream-card__label {
  font-size: 0.65rem;
  color:     var(--text-dim);
}

/* ============================================================================
   Phase 28 — Signal Decay Engine: Relevance Bar
   ============================================================================ */

/* ── Relevance bar — signal monitor rows ─────────────────────────────────── */

.rel-bar {
  display:     flex;
  align-items: center;
  gap:         var(--sp-2);
  min-width:   64px;
}

.rel-bar__track {
  flex:          1;
  height:        4px;
  background:    var(--bg-elevated);
  border-radius: 2px;
  overflow:      hidden;
  min-width:     36px;
}

.rel-bar__fill {
  height:        100%;
  border-radius: 2px;
  transition:    width 0.4s ease;
  min-width:     2px;
}

/* Three decay states match the engine thresholds */
.rel-bar__fill--fresh  { background: #34d399; }   /* ≥ 0.60 — emerald */
.rel-bar__fill--fading { background: #c8943a; }   /* 0.20–0.59 — amber */
.rel-bar__fill--stale  { background: #4a6070; }   /* < 0.20 — grey */

.rel-bar__val {
  font-size:   0.58rem;
  color:       var(--text-ghost);
  flex-shrink: 0;
  width:       28px;
  text-align:  right;
}